# Video Editor Skill — Environment Variables
# Copy this to .env and fill in your values.
# The install.sh script does this automatically.

# ── Platform API (required for DAM integration) ──────────
# Generate at: https://your-platform.vercel.app/admin/integrations/api-keys
CGK_PLATFORM_API_URL=https://your-platform.vercel.app
CGK_PLATFORM_API_KEY=
CGK_PLATFORM_TENANT_SLUG=your_tenant_slug

# ── Stock Footage (optional) ─────────────────────────────
# https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Sound Effects (optional) ─────────────────────────────
# https://freesound.org/apiv2/apply
FREESOUND_API_KEY=
