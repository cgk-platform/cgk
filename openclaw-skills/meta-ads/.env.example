# Meta Ads Skill — Environment Variables
# Copy this to .env and fill in your values.
# The install.sh script does this automatically.

# ── Per-Brand Ad Account (required) ──────────────────────
# Each profile/brand needs its own ad account.
# Find at: https://business.facebook.com/settings/ad-accounts
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_BUSINESS_ID=
META_PIXEL_ID=

# ── Meta App Credentials (required) ──────────────────────
# These are typically shared across profiles.
# Create at: https://developers.facebook.com/apps/
# If already set in your profile .env, you can omit these.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
