{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm turbo build --filter=admin --filter=storefront --filter=creator-portal --filter=contractor-portal --filter=orchestrator --filter=shopify-app --filter=command-center --filter=mcp-server",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "regions": ["iad1"],
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/apps/admin/:path*" },
    { "source": "/creator/:path*", "destination": "/apps/creator-portal/:path*" },
    { "source": "/contractor/:path*", "destination": "/apps/contractor-portal/:path*" },
    { "source": "/orchestrator/:path*", "destination": "/apps/orchestrator/:path*" },
    { "source": "/shopify-app/:path*", "destination": "/apps/shopify-app/:path*" },
    { "source": "/command-center/:path*", "destination": "/apps/command-center/:path*" },
    { "source": "/mcp/:path*", "destination": "/apps/mcp-server/:path*" },
    { "source": "/:path*", "destination": "/apps/storefront/:path*" }
  ],
  "functions": {
    "apps/*/src/app/api/**": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PNPM_VERSION": "10"
  },
  "build": {
    "env": {
      "GENERATE_SECRETS": "true",
      "TURBO_TELEMETRY_DISABLED": "1"
    }
  },
  "integrations": {
    "neon": {
      "required": true,
      "description": "PostgreSQL database for multi-tenant data storage"
    },
    "upstash": {
      "required": true,
      "description": "Redis for session caching, rate limiting, and job queues"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "crons": []
}
