# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3300"

# Database (shared across all CGK apps)
DATABASE_URL="<POSTGRES_URL>"
POSTGRES_URL="<POSTGRES_URL>"

# Redis/KV (shared across all CGK apps)
KV_REST_API_TOKEN="<KV_TOKEN>"
KV_REST_API_URL="<KV_URL>"
KV_URL="<KV_URL>"

# Shopify Configuration
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN="meliusly.myshopify.com"
SHOPIFY_CLIENT_ID="<SHOPIFY_CLIENT_ID>"
SHOPIFY_CLIENT_SECRET="<SHOPIFY_CLIENT_SECRET>"
SHOPIFY_API_VERSION="2026-01"

# Shopify Storefront Access Token
# Generate via Admin API mutation:
# mutation {
#   storefrontAccessTokenCreate(input: {
#     title: "Meliusly Headless Storefront"
#   }) {
#     storefrontAccessToken { accessToken }
#   }
# }
SHOPIFY_STOREFRONT_ACCESS_TOKEN="<STOREFRONT_TOKEN>"

# Encryption Keys (shared across all CGK apps)
INTEGRATION_ENCRYPTION_KEY="<INTEGRATION_ENCRYPTION_KEY>"
SHOPIFY_TOKEN_ENCRYPTION_KEY="<SHOPIFY_TOKEN_ENCRYPTION_KEY>"
