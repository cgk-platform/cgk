# CGK Platform Shopify App Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values

# ===================
# SHOPIFY APP OAUTH
# ===================
# From Shopify Partners Dashboard -> Client credentials

# Client ID (also in shopify.app.toml)
SHOPIFY_CLIENT_ID=your-client-id-from-partners

# Client Secret (NEVER commit this)
SHOPIFY_CLIENT_SECRET=your-client-secret-from-partners

# Legacy alias (some older code uses this)
RAWDOG_FUNCTIONS_API_SECRET=your-client-secret

# ===================
# TOKEN ENCRYPTION
# ===================
# Used to encrypt OAuth access tokens before storing in database
# Generate with: openssl rand -hex 32

SHOPIFY_TOKEN_ENCRYPTION_KEY=64-character-hex-key-here

# ===================
# WEBHOOK VERIFICATION
# ===================
# Used to verify Shopify webhook signatures
# Can use the same value as SHOPIFY_CLIENT_SECRET

SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ===================
# API VERSION
# ===================
# Shopify API version for REST and GraphQL calls

SHOPIFY_API_VERSION=2026-01

# ===================
# WEB PIXEL SETTINGS
# ===================
# For session stitching between pre-checkout and post-purchase

# GA4 Measurement Protocol
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_MEASUREMENT_PROTOCOL_SECRET=your-ga4-api-secret

# Meta/Facebook CAPI
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id
META_CAPI_ACCESS_TOKEN=your-meta-capi-token

# ===================
# PLATFORM URLS
# ===================
# Base URL for OAuth redirects and webhooks

NEXT_PUBLIC_BASE_URL=https://admin.cgk-platform.com

# API endpoint for platform events
PLATFORM_API_URL=https://admin.cgk-platform.com/api

# ===================
# CGK PLATFORM SYNC
# ===================
# URL and API key for syncing bundle config and order webhooks to the admin API
# API key must match what's set on the admin app side
# Generate with: openssl rand -base64 32

CGK_PLATFORM_API_URL=https://cgk-admin.vercel.app
CGK_PLATFORM_API_KEY=your-shared-api-key
CGK_TENANT_SLUG=cgk_linens

# ===================
# DATABASE (Shopify OAuth session storage)
# ===================
# Uses the same Neon PostgreSQL as the admin app
# Table: public.shopify_sessions (created via SQL, not Prisma migrate)

DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ===================
# DEVELOPMENT
# ===================
# Development store for testing

SHOPIFY_DEV_STORE=your-dev-store.myshopify.com

# ===================
# CI/CD (GitHub Actions)
# ===================
# Set these as GitHub Secrets, not here

# SHOPIFY_CLI_PARTNERS_TOKEN - Create at Partners Dashboard -> Settings -> CLI tokens
