{% doc %}
  Bundle product card snippet.

  @param {product} product - The product to render
  @param {number} index - Position index in the bundle grid
  @param {string} aspect_css - CSS aspect-ratio value (e.g. '1', '3/4', '4/3')
  @param {boolean} is_free_gift - Whether this card is a free gift (shows FREE badge)
{% enddoc %}

{%- if product != blank -%}
  {%- assign first_variant = product.selected_or_first_available_variant -%}
  {%- assign card_aspect = aspect_css | default: '1' -%}
  {%- assign is_sold_out = false -%}
  {%- unless first_variant.available -%}
    {%- assign is_sold_out = true -%}
  {%- endunless -%}
  {%- assign has_variants = false -%}
  {%- if product.variants.size > 1 -%}
    {%- assign has_variants = true -%}
  {%- endif -%}

  {%- comment -%} Compute image height from aspect ratio for proper intrinsic sizing {%- endcomment -%}
  {%- case card_aspect -%}
    {%- when '3/4' -%}
      {%- assign img_height = 533 -%}
    {%- when '4/3' -%}
      {%- assign img_height = 300 -%}
    {%- else -%}
      {%- assign img_height = 400 -%}
  {%- endcase -%}

  {%- comment -%} Build variants JSON for JS consumption {%- endcomment -%}
  {%- if has_variants -%}
    {%- capture variants_json -%}
    [
      {%- for variant in product.variants -%}
        {%- if forloop.first == false -%},{%- endif -%}
        {"id":"{{ variant.id }}","title":{{ variant.title | json }},"price":{{ variant.price }},"available":{{ variant.available }}}
      {%- endfor -%}
    ]
    {%- endcapture -%}
  {%- endif -%}

  <div
    class="bb-card{% if is_sold_out %} bb-card--sold-out{% endif %}"
    data-product-id="{{ product.id }}"
    data-variant-id="{{ first_variant.id }}"
    data-price="{{ first_variant.price }}"
    data-compare-price="{{ first_variant.compare_at_price | default: first_variant.price }}"
    data-title="{{ product.title | escape }}"
    data-index="{{ index }}"
    data-available="{{ first_variant.available }}"
    {%- if has_variants %} data-variants="{{ variants_json | strip_newlines | escape }}"{% endif %}
    role="button"
    tabindex="{% if is_sold_out %}-1{% else %}0{% endif %}"
    aria-pressed="false"
    aria-label="{% if is_sold_out %}{{ product.title }} — Sold out{% else %}Add {{ product.title }} to bundle{% endif %}"
    {% if is_sold_out %}aria-disabled="true"{% endif %}
  >
    <div class="bb-card__image-wrap" style="aspect-ratio: {{ card_aspect }};">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 400 }}"
          srcset="{{ product.featured_image | image_url: width: 200 }} 200w,
                  {{ product.featured_image | image_url: width: 400 }} 400w,
                  {{ product.featured_image | image_url: width: 600 }} 600w,
                  {{ product.featured_image | image_url: width: 800 }} 800w"
          sizes="(max-width: 374px) 100vw, (max-width: 639px) 50vw, 33vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="bb-card__image"
          width="400"
          height="{{ img_height }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="bb-card__image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="bb-card__placeholder-icon">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="m21 15-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}
      {%- if is_sold_out -%}
        <div class="bb-card__badge bb-card__badge--sold-out">Sold Out</div>
      {%- endif -%}
      {%- if is_free_gift -%}
        <div class="bb-card__badge bb-card__badge--free-gift">FREE</div>
      {%- endif -%}
      <div class="bb-card__check">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
    </div>

    <div class="bb-card__info">
      <h3 class="bb-card__title">{{ product.title }}</h3>
      {%- if has_variants -%}
        <div class="bb-card__variant-select">
          <select class="bb-variant-picker" aria-label="Select variant for {{ product.title | escape }}" data-action="variant-change">
            {%- for variant in product.variants -%}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price }}"
                data-available="{{ variant.available }}"
                {% if variant == first_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %} — {{ variant.price | money }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- endif -%}
      <div class="bb-card__pricing">
        {%- if first_variant.compare_at_price > first_variant.price -%}
          <span class="bb-card__compare-price">{{ first_variant.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="bb-card__price">{{ first_variant.price | money }}</span>
      </div>
    </div>

    <div class="bb-card__quantity">
      <button type="button" class="bb-qty-btn bb-qty-btn--minus" aria-label="Decrease quantity for {{ product.title | escape }}" data-action="decrease">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <span class="bb-qty-value" aria-live="polite">1</span>
      <button type="button" class="bb-qty-btn bb-qty-btn--plus" aria-label="Increase quantity for {{ product.title | escape }}" data-action="increase">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
    </div>
  </div>
{%- endif -%}
