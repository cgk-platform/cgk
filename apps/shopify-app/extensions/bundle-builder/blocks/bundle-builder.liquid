{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

{%- comment -%} Read bundle config from app metafield (source of truth from Shopify embedded app) {%- endcomment -%}
{%- assign metafield_config_raw = app.metafields["bundle-discount"]["config"].value -%}
{%- assign has_metafield_config = false -%}
{%- if metafield_config_raw != blank -%}
  {%- assign has_metafield_config = true -%}
{%- endif -%}

{%- liquid
  assign headline = block.settings.headline
  assign subheadline = block.settings.subheadline
  assign cta_text = block.settings.cta_text | default: 'Add Bundle to Cart'
  assign show_savings = block.settings.show_savings
  assign show_tier_progress = block.settings.show_tier_progress
  assign cart_redirect = block.settings.cart_redirect
  assign layout = block.settings.layout | default: 'grid'
  assign columns_desktop = block.settings.columns_desktop | default: 3
  assign bg_color = block.settings.bg_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#1a1a2e'
  assign accent_color = block.settings.accent_color | default: '#2563eb'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
  assign padding_top = block.settings.padding_top | default: 48
  assign padding_bottom = block.settings.padding_bottom | default: 48
  assign image_ratio = block.settings.image_ratio | default: 'square'
  assign bundle_name = block.settings.bundle_name | default: 'Custom Bundle'
  assign min_items = block.settings.min_items
  assign max_items = block.settings.max_items
-%}

{%- comment -%}
  Metafield-driven config (Pattern E hybrid):
  Business data (tiers, discount type, bundle ID, free gifts) comes from the
  $app:bundle-discount/config metafield written by the Shopify embedded app.
  Visual settings (colors, layout, columns, spacing) stay in block schema.
  Falls back to block schema settings if metafield is empty (first install).
{%- endcomment -%}

{%- if has_metafield_config -%}
  {%- comment -%}
    Metafield config is a JSON string like:
    {"bundles":[{"bundleId":"...","discountType":"percentage","tiers":[...],"freeGiftVariantIds":[...]}]}
    We pass the raw JSON string to JS for parsing — Liquid can't natively parse nested JSON.
    JS will extract: discountType, tiers, bundleId, freeGiftVariantIds.
  {%- endcomment -%}
  {%- assign tiers_json = '[]' -%}
  {%- assign discount_type = 'percentage' -%}
  {%- assign bundle_id_attr = '' -%}
  {%- assign free_gift_variant_ids = '' -%}
{%- else -%}
  {%- comment -%} Fallback: read from block schema settings (backward compat for first install) {%- endcomment -%}
  {%- assign discount_type = block.settings.discount_type | default: 'percentage' -%}
  {%- assign bundle_id_attr = block.id -%}

  {%- capture tiers_json -%}
[
  {%- assign tier_count = 0 -%}
  {%- assign t2_gift = block.settings.tier_2_free_gift_variant_id -%}
  {%- assign t2_icon = block.settings.tier_2_icon -%}
  {%- assign t3_gift = block.settings.tier_3_free_gift_variant_id -%}
  {%- assign t3_icon = block.settings.tier_3_icon -%}
  {%- assign t4_gift = block.settings.tier_4_free_gift_variant_id -%}
  {%- assign t4_icon = block.settings.tier_4_icon -%}
  {%- assign t5_gift = block.settings.tier_5_free_gift_variant_id -%}
  {%- assign t5_icon = block.settings.tier_5_icon -%}
  {%- if block.settings.discount_2_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":2,"discount":{{ block.settings.discount_2_items }},"label":{{ block.settings.tier_2_label | default: 'Starter Bundle' | json }}
    {%- if t2_gift != blank -%},"freeGiftVariantId":"{{ t2_gift }}"{%- endif -%}
    {%- if t2_icon -%},"icon":"{{ t2_icon | image_url: width: 48 }}"{%- endif -%}
    }
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_3_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":3,"discount":{{ block.settings.discount_3_items }},"label":{{ block.settings.tier_3_label | default: 'Value Bundle' | json }}
    {%- if t3_gift != blank -%},"freeGiftVariantId":"{{ t3_gift }}"{%- endif -%}
    {%- if t3_icon -%},"icon":"{{ t3_icon | image_url: width: 48 }}"{%- endif -%}
    }
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_4_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":4,"discount":{{ block.settings.discount_4_items }},"label":{{ block.settings.tier_4_label | default: 'Best Value' | json }}
    {%- if t4_gift != blank -%},"freeGiftVariantId":"{{ t4_gift }}"{%- endif -%}
    {%- if t4_icon -%},"icon":"{{ t4_icon | image_url: width: 48 }}"{%- endif -%}
    }
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_5_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":5,"discount":{{ block.settings.discount_5_items }},"label":{{ block.settings.tier_5_label | default: 'Ultimate Bundle' | json }}
    {%- if t5_gift != blank -%},"freeGiftVariantId":"{{ t5_gift }}"{%- endif -%}
    {%- if t5_icon -%},"icon":"{{ t5_icon | image_url: width: 48 }}"{%- endif -%}
    }
  {%- endif -%}
]
  {%- endcapture -%}

  {%- capture free_gift_variant_ids -%}
    {%- if block.settings.tier_2_free_gift_variant_id != blank -%},{{ block.settings.tier_2_free_gift_variant_id }},{%- endif -%}
    {%- if block.settings.tier_3_free_gift_variant_id != blank -%},{{ block.settings.tier_3_free_gift_variant_id }},{%- endif -%}
    {%- if block.settings.tier_4_free_gift_variant_id != blank -%},{{ block.settings.tier_4_free_gift_variant_id }},{%- endif -%}
    {%- if block.settings.tier_5_free_gift_variant_id != blank -%},{{ block.settings.tier_5_free_gift_variant_id }},{%- endif -%}
  {%- endcapture -%}
{%- endif -%}

{%- comment -%} Map image ratio to CSS aspect-ratio {%- endcomment -%}
{%- case image_ratio -%}
  {%- when 'portrait' -%}
    {%- assign aspect_css = '3/4' -%}
  {%- when 'landscape' -%}
    {%- assign aspect_css = '4/3' -%}
  {%- else -%}
    {%- assign aspect_css = '1' -%}
{%- endcase -%}

{%- comment -%} Collect products from product_list setting {%- endcomment -%}
{%- assign products = block.settings.products -%}
{%- assign product_count = products | size -%}

<div
  class="bb-container"
  data-bundle-builder
  data-section-id="{{ section.id }}"
  data-block-id="{{ block.id }}"
  data-discount-type="{{ discount_type }}"
  data-min-items="{{ min_items }}"
  data-max-items="{{ max_items }}"
  data-show-savings="{{ show_savings }}"
  data-show-tier-progress="{{ show_tier_progress }}"
  data-bundle-name="{{ bundle_name | escape }}"
  data-cta-text="{{ cta_text | escape }}"
  data-cart-redirect="{{ cart_redirect }}"
  data-tiers="{{ tiers_json | strip_newlines | escape }}"
  data-money-format="{{ shop.money_format | escape }}"
  {%- if has_metafield_config %}
  data-metafield-config="{{ metafield_config_raw | escape }}"
  {%- endif -%}
  {%- if bundle_id_attr != blank %}
  data-bundle-id="{{ bundle_id_attr }}"
  {%- endif -%}
  role="region"
  aria-label="{{ bundle_name | escape }}"
  style="--bb-bg-color: {{ bg_color }}; --bb-text-color: {{ text_color }}; --bb-accent-color: {{ accent_color }}; --bb-btn-text-color: {{ button_text_color }}; --bb-padding-top: {{ padding_top }}px; --bb-padding-bottom: {{ padding_bottom }}px;"
>
  {%- if headline != blank or subheadline != blank -%}
    <div class="bb-header">
      {%- if headline != blank -%}
        <h2 class="bb-headline">{{ headline }}</h2>
      {%- endif -%}
      {%- if subheadline != blank -%}
        <p class="bb-subheadline">{{ subheadline }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if product_count > 0 -%}
    {%- if layout == 'grid' -%}
      <div class="bb-grid bb-grid--{{ columns_desktop }}col">
    {%- else -%}
      <div class="bb-list">
    {%- endif -%}

    {%- for product in products -%}
      {%- assign variant_check = product.selected_or_first_available_variant.id | prepend: ',' | append: ',' -%}
      {%- assign is_gift = false -%}
      {%- if free_gift_variant_ids contains variant_check -%}{%- assign is_gift = true -%}{%- endif -%}
      {%- render 'bundle-product-card', product: product, index: forloop.index, aspect_css: aspect_css, is_free_gift: is_gift -%}
    {%- endfor -%}

    {%- if layout == 'grid' -%}
      </div>
    {%- else -%}
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="bb-empty">
      <p>Select products in the theme editor to build your bundle.</p>
    </div>
  {%- endif -%}

  {%- comment -%} Tier unlock notification (hidden by default, shown by JS) {%- endcomment -%}
  <div class="bb-notification" aria-live="polite" role="status"></div>

  {%- if show_tier_progress -%}
    <div class="bb-tier">
      <p class="bb-tier__label">Select items to unlock discounts</p>
      <div class="bb-tier__bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Discount tier progress">
        <div class="bb-tier__fill"></div>
      </div>
      <p class="bb-tier__hint" aria-hidden="true"></p>
    </div>
  {%- endif -%}

  <div class="bb-savings" hidden>You save $0.00!</div>

  <div class="bb-summary" aria-live="polite">
    <div class="bb-summary__row">
      <span>Items selected</span>
      <span data-summary="count">0</span>
    </div>
    <div class="bb-summary__row bb-summary__row--tier" style="display: none;">
      <span>Active tier</span>
      <span data-summary="tier" class="bb-tier-badge"></span>
    </div>
    <div class="bb-summary__row">
      <span>Subtotal</span>
      <span data-summary="subtotal">{{ 0 | money }}</span>
    </div>
    <div class="bb-summary__row bb-summary__row--discount" style="display: none;">
      <span>Bundle discount</span>
      <span data-summary="discount">-{{ 0 | money }}</span>
    </div>
    <div class="bb-summary__row bb-summary__row--total">
      <span>Total</span>
      <span data-summary="total">{{ 0 | money }}</span>
    </div>
  </div>

  <button type="button" class="bb-cta" disabled>
    {{ cta_text }}
  </button>
</div>

<script src="{{ 'bundle-builder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bundle Builder",
  "target": "section",
  "presets": [
    {
      "name": "Bundle Builder"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "bundle_name",
      "label": "Bundle name",
      "default": "Custom Bundle",
      "info": "Internal name for this bundle (shown in order line item properties)"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Build Your Bundle & Save"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Mix & match your favorites — the more you add, the more you save."
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Bundle products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Discount Tiers"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Discount type (fallback)",
      "options": [
        { "value": "percentage", "label": "Percentage off" },
        { "value": "fixed", "label": "Fixed amount off" }
      ],
      "default": "percentage",
      "info": "Overridden by the Bundle Builder app config when a bundle discount is configured. Only used as a fallback if no app config exists."
    },
    {
      "type": "range",
      "id": "discount_2_items",
      "label": "Discount for 2 items (fallback)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "info": "Fallback only — tier discounts are managed in the Bundle Builder app. Set to 0 to disable."
    },
    {
      "type": "text",
      "id": "tier_2_label",
      "label": "Tier 2 label",
      "default": "Starter Bundle",
      "info": "Shown in the progress bar and summary when this tier is active"
    },
    {
      "type": "text",
      "id": "tier_2_free_gift_variant_id",
      "label": "Tier 2 free gift variant ID",
      "info": "Fallback only — free gifts are managed in the Bundle Builder app."
    },
    {
      "type": "image_picker",
      "id": "tier_2_icon",
      "label": "Tier 2 icon",
      "info": "Small icon for tier unlock notification (recommended: 48x48px)"
    },
    {
      "type": "range",
      "id": "discount_3_items",
      "label": "Discount for 3 items (fallback)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 15,
      "info": "Fallback only — managed in the Bundle Builder app."
    },
    {
      "type": "text",
      "id": "tier_3_label",
      "label": "Tier 3 label",
      "default": "Value Bundle"
    },
    {
      "type": "text",
      "id": "tier_3_free_gift_variant_id",
      "label": "Tier 3 free gift variant ID",
      "info": "Fallback only — free gifts are managed in the Bundle Builder app."
    },
    {
      "type": "image_picker",
      "id": "tier_3_icon",
      "label": "Tier 3 icon",
      "info": "Small icon for tier unlock notification (recommended: 48x48px)"
    },
    {
      "type": "range",
      "id": "discount_4_items",
      "label": "Discount for 4 items (fallback)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20,
      "info": "Fallback only — managed in the Bundle Builder app."
    },
    {
      "type": "text",
      "id": "tier_4_label",
      "label": "Tier 4 label",
      "default": "Best Value"
    },
    {
      "type": "text",
      "id": "tier_4_free_gift_variant_id",
      "label": "Tier 4 free gift variant ID",
      "info": "Fallback only — free gifts are managed in the Bundle Builder app."
    },
    {
      "type": "image_picker",
      "id": "tier_4_icon",
      "label": "Tier 4 icon",
      "info": "Small icon for tier unlock notification (recommended: 48x48px)"
    },
    {
      "type": "range",
      "id": "discount_5_items",
      "label": "Discount for 5+ items (fallback)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 25,
      "info": "Fallback only — managed in the Bundle Builder app."
    },
    {
      "type": "text",
      "id": "tier_5_label",
      "label": "Tier 5+ label",
      "default": "Ultimate Bundle"
    },
    {
      "type": "text",
      "id": "tier_5_free_gift_variant_id",
      "label": "Tier 5 free gift variant ID",
      "info": "Fallback only — free gifts are managed in the Bundle Builder app."
    },
    {
      "type": "image_picker",
      "id": "tier_5_icon",
      "label": "Tier 5 icon",
      "info": "Small icon for tier unlock notification (recommended: 48x48px)"
    },
    {
      "type": "header",
      "content": "Bundle Limits"
    },
    {
      "type": "range",
      "id": "min_items",
      "label": "Minimum items to unlock cart",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum items allowed",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Product layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Grid columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Button & Behavior"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show savings callout",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tier_progress",
      "label": "Show tier progress bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "cart_redirect",
      "label": "Redirect to cart after adding",
      "default": false,
      "info": "When enabled, the customer is sent to /cart after adding the bundle. Otherwise stays on the page with a success message."
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff",
      "info": "Text color for the Add to Cart button. Use white for dark accent colors, dark for light accents."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ]
}
{% endschema %}
