{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bundle_name = block.settings.bundle_name | default: 'Custom Bundle'
  assign headline = block.settings.headline
  assign subheadline = block.settings.subheadline
  assign discount_type = 'percentage'
  assign min_items = block.settings.min_items
  assign max_items = block.settings.max_items
  assign cta_text = block.settings.cta_text | default: 'Add Bundle to Cart'
  assign show_savings = block.settings.show_savings
  assign show_tier_progress = block.settings.show_tier_progress
  assign cart_redirect = block.settings.cart_redirect
  assign layout = block.settings.layout | default: 'grid'
  assign columns_desktop = block.settings.columns_desktop | default: 3
  assign bg_color = block.settings.bg_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#1a1a2e'
  assign accent_color = block.settings.accent_color | default: '#2563eb'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
  assign padding_top = block.settings.padding_top | default: 48
  assign padding_bottom = block.settings.padding_bottom | default: 48
  assign image_ratio = block.settings.image_ratio | default: 'square'
-%}

{%- comment -%} Build tiers JSON from settings — includes icon URLs and free gift variant IDs {%- endcomment -%}
{%- capture tiers_json -%}
[
  {%- assign tier_count = 0 -%}
  {%- if block.settings.discount_2_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":2,"discount":{{ block.settings.discount_2_items }},"label":{{ block.settings.tier_2_label | default: 'Starter Bundle' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_3_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":3,"discount":{{ block.settings.discount_3_items }},"label":{{ block.settings.tier_3_label | default: 'Value Bundle' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_4_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":4,"discount":{{ block.settings.discount_4_items }},"label":{{ block.settings.tier_4_label | default: 'Best Value' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_5_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":5,"discount":{{ block.settings.discount_5_items }},"label":{{ block.settings.tier_5_label | default: 'Ultimate Bundle' | json }}}
  {%- endif -%}
]
{%- endcapture -%}

{%- comment -%} Map image ratio to CSS aspect-ratio {%- endcomment -%}
{%- case image_ratio -%}
  {%- when 'portrait' -%}
    {%- assign aspect_css = '3/4' -%}
  {%- when 'landscape' -%}
    {%- assign aspect_css = '4/3' -%}
  {%- else -%}
    {%- assign aspect_css = '1' -%}
{%- endcase -%}

{%- comment -%} Collect products from product_list setting {%- endcomment -%}
{%- assign products = block.settings.products -%}
{%- assign product_count = products | size -%}

<div
  class="bb-container"
  data-bundle-builder
  data-section-id="{{ section.id }}"
  data-block-id="{{ block.id }}"
  data-discount-type="{{ discount_type }}"
  data-min-items="{{ min_items }}"
  data-max-items="{{ max_items }}"
  data-show-savings="{{ show_savings }}"
  data-show-tier-progress="{{ show_tier_progress }}"
  data-bundle-name="{{ bundle_name | escape }}"
  data-cta-text="{{ cta_text | escape }}"
  data-cart-redirect="{{ cart_redirect }}"
  data-tiers="{{ tiers_json | strip_newlines | escape }}"
  data-money-format="{{ shop.money_format | escape }}"
  role="region"
  aria-label="{{ bundle_name | escape }}"
  style="--bb-bg-color: {{ bg_color }}; --bb-text-color: {{ text_color }}; --bb-accent-color: {{ accent_color }}; --bb-btn-text-color: {{ button_text_color }}; --bb-padding-top: {{ padding_top }}px; --bb-padding-bottom: {{ padding_bottom }}px;"
>
  {%- if headline != blank or subheadline != blank -%}
    <div class="bb-header">
      {%- if headline != blank -%}
        <h2 class="bb-headline">{{ headline }}</h2>
      {%- endif -%}
      {%- if subheadline != blank -%}
        <p class="bb-subheadline">{{ subheadline }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if product_count > 0 -%}
    {%- if layout == 'grid' -%}
      <div class="bb-grid bb-grid--{{ columns_desktop }}col">
    {%- else -%}
      <div class="bb-list">
    {%- endif -%}

    {%- for product in products -%}
      {%- render 'bundle-product-card', product: product, index: forloop.index, aspect_css: aspect_css, is_free_gift: false -%}
    {%- endfor -%}

    {%- if layout == 'grid' -%}
      </div>
    {%- else -%}
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="bb-empty">
      <p>Select products in the theme editor to build your bundle.</p>
    </div>
  {%- endif -%}

  {%- comment -%} Tier unlock notification (hidden by default, shown by JS) {%- endcomment -%}
  <div class="bb-notification" aria-live="polite" role="status"></div>

  {%- if show_tier_progress -%}
    <div class="bb-tier">
      <p class="bb-tier__label">Select items to unlock discounts</p>
      <div class="bb-tier__bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Discount tier progress">
        <div class="bb-tier__fill"></div>
      </div>
      <p class="bb-tier__hint" aria-hidden="true"></p>
    </div>
  {%- endif -%}

  <div class="bb-savings" hidden>You save $0.00!</div>

  <div class="bb-summary" aria-live="polite">
    <div class="bb-summary__row">
      <span>Items selected</span>
      <span data-summary="count">0</span>
    </div>
    <div class="bb-summary__row bb-summary__row--tier" style="display: none;">
      <span>Active tier</span>
      <span data-summary="tier" class="bb-tier-badge"></span>
    </div>
    <div class="bb-summary__row">
      <span>Subtotal</span>
      <span data-summary="subtotal">{{ 0 | money }}</span>
    </div>
    <div class="bb-summary__row bb-summary__row--discount" style="display: none;">
      <span>Bundle discount</span>
      <span data-summary="discount">-{{ 0 | money }}</span>
    </div>
    <div class="bb-summary__row bb-summary__row--total">
      <span>Total</span>
      <span data-summary="total">{{ 0 | money }}</span>
    </div>
  </div>

  <button type="button" class="bb-cta" disabled>
    {{ cta_text }}
  </button>
</div>

<script src="{{ 'bundle-builder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bundle Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "bundle_name",
      "label": "Bundle name",
      "default": "Custom Bundle",
      "info": "Internal name for this bundle (shown in order line item properties)"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Build Your Bundle & Save"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Mix & match your favorites — the more you add, the more you save."
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Bundle products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Discount Tiers"
    },
    {
      "type": "range",
      "id": "discount_2_items",
      "label": "Discount for 2 items (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "info": "Percentage off. Set to 0 to disable this tier."
    },
    {
      "type": "text",
      "id": "tier_2_label",
      "label": "Tier 2 label",
      "default": "Starter Bundle",
      "info": "Shown in the progress bar and summary when this tier is active"
    },
    {
      "type": "range",
      "id": "discount_3_items",
      "label": "Discount for 3 items (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 15,
      "info": "Percentage off. Set to 0 to disable."
    },
    {
      "type": "text",
      "id": "tier_3_label",
      "label": "Tier 3 label",
      "default": "Value Bundle"
    },
    {
      "type": "range",
      "id": "discount_4_items",
      "label": "Discount for 4 items (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20,
      "info": "Percentage off. Set to 0 to disable."
    },
    {
      "type": "text",
      "id": "tier_4_label",
      "label": "Tier 4 label",
      "default": "Best Value"
    },
    {
      "type": "range",
      "id": "discount_5_items",
      "label": "Discount for 5+ items (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 25,
      "info": "Percentage off. Set to 0 to disable."
    },
    {
      "type": "text",
      "id": "tier_5_label",
      "label": "Tier 5+ label",
      "default": "Ultimate Bundle"
    },
    {
      "type": "header",
      "content": "Bundle Limits"
    },
    {
      "type": "range",
      "id": "min_items",
      "label": "Minimum items to unlock cart",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum items allowed",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Product layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Grid columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Button & Behavior"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show savings callout",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tier_progress",
      "label": "Show tier progress bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "cart_redirect",
      "label": "Redirect to cart after adding",
      "default": false,
      "info": "When enabled, the customer is sent to /cart after adding the bundle. Otherwise stays on the page with a success message."
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff",
      "info": "Text color for the Add to Cart button. Use white for dark accent colors, dark for light accents."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ]
}
{% endschema %}
