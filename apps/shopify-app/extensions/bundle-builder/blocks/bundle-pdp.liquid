{{ 'bundle-pdp.css' | asset_url | stylesheet_tag }}

{%- comment -%} Read bundle config from app metafield {%- endcomment -%}
{%- assign metafield_config_raw = app.metafields["bundle-discount"]["config"].value -%}
{%- assign has_metafield_config = false -%}
{%- if metafield_config_raw != blank -%}
  {%- assign has_metafield_config = true -%}
{%- endif -%}

{%- liquid
  assign headline = block.settings.headline
  assign cta_text = block.settings.cta_text | default: 'Add Bundle to Cart'
  assign show_savings = block.settings.show_savings
  assign show_tier_progress = block.settings.show_tier_progress
  assign cart_redirect = block.settings.cart_redirect
  assign bg_color = block.settings.bg_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#1a1a2e'
  assign accent_color = block.settings.accent_color | default: '#182f5c'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
  assign padding_top = block.settings.padding_top | default: 48
  assign padding_bottom = block.settings.padding_bottom | default: 48
  assign bundle_name = block.settings.bundle_name | default: 'Custom Bundle'
  assign min_items = block.settings.min_items
  assign max_items = block.settings.max_items
  assign show_variant_selector = block.settings.show_variant_selector
  assign show_reviews = block.settings.show_reviews
  assign show_trust_badges = block.settings.show_trust_badges
-%}

{%- if has_metafield_config -%}
  {%- assign tiers_json = '[]' -%}
  {%- assign discount_type = 'percentage' -%}
  {%- assign bundle_id_attr = '' -%}
{%- else -%}
  {%- assign discount_type = block.settings.discount_type | default: 'percentage' -%}
  {%- assign bundle_id_attr = block.id -%}
  {%- capture tiers_json -%}
[
  {%- assign tier_count = 0 -%}
  {%- if block.settings.discount_2_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":2,"discount":{{ block.settings.discount_2_items }},"label":{{ block.settings.tier_2_label | default: '' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_3_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":3,"discount":{{ block.settings.discount_3_items }},"label":{{ block.settings.tier_3_label | default: '' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_4_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":4,"discount":{{ block.settings.discount_4_items }},"label":{{ block.settings.tier_4_label | default: '' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_5_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":5,"discount":{{ block.settings.discount_5_items }},"label":{{ block.settings.tier_5_label | default: '' | json }}}
  {%- endif -%}
]
  {%- endcapture -%}
{%- endif -%}

{%- assign bundle_products = block.settings.products -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} Build variant JSON for JS {%- endcomment -%}
{%- capture variants_json -%}
[
  {%- for variant in product.variants -%}
    {%- if forloop.index > 1 -%},{%- endif -%}
    {
      "id":{{ variant.id }},
      "available":{{ variant.available }},
      "price":{{ variant.price }},
      "compare_at_price":{{ variant.compare_at_price | default: 'null' }},
      "options":{{ variant.options | json }},
      "featured_media_id":{{ variant.featured_media.id | default: 'null' }}
    }
  {%- endfor -%}
]
{%- endcapture -%}

<div
  class="bb-pdp"
  data-bundle-pdp
  data-section-id="{{ section.id }}"
  data-block-id="{{ block.id }}"
  data-discount-type="{{ discount_type }}"
  data-min-items="{{ min_items }}"
  data-max-items="{{ max_items }}"
  data-show-savings="{{ show_savings }}"
  data-show-tier-progress="{{ show_tier_progress }}"
  data-bundle-name="{{ bundle_name | escape }}"
  data-cta-text="{{ cta_text | escape }}"
  data-cart-redirect="{{ cart_redirect }}"
  data-tiers="{{ tiers_json | strip_newlines | escape }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-product-url="{{ product.url }}"
  {%- if has_metafield_config %}
  data-metafield-config="{{ metafield_config_raw | escape }}"
  {%- endif -%}
  {%- if bundle_id_attr != blank %}
  data-bundle-id="{{ bundle_id_attr }}"
  {%- endif -%}
  role="region"
  aria-label="{{ bundle_name | escape }} product page"
  style="--bb-bg-color: {{ bg_color }}; --bb-text-color: {{ text_color }}; --bb-accent-color: {{ accent_color }}; --bb-btn-text-color: {{ button_text_color }}; --bb-padding-top: {{ padding_top }}px; --bb-padding-bottom: {{ padding_bottom }}px;"
>
  {%- comment -%} Variant data for JS {%- endcomment -%}
  <script type="application/json" data-pdp-variants>{{ variants_json | strip_newlines }}</script>

  <div class="bb-pdp__layout">
    {%- comment -%} ===== Left column: Image gallery ===== {%- endcomment -%}
    <div class="bb-pdp__gallery">
      <div class="bb-pdp__main-image-container">
        <div class="bb-pdp__main-image" data-pdp-main-image>
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 900 }}"
              srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                      {{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 900 }} 900w,
                      {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 899px) 100vw, 55vw"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              loading="eager"
              data-pdp-main-img
            >
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <button type="button" class="bb-pdp__arrow bb-pdp__arrow--prev" data-pdp-arrow="prev" aria-label="Previous image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button type="button" class="bb-pdp__arrow bb-pdp__arrow--next" data-pdp-arrow="next" aria-label="Next image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="bb-pdp__thumbs" data-pdp-thumbs>
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              <button
                type="button"
                class="bb-pdp__thumb{% if media.id == current_variant.featured_media.id or forloop.first and current_variant.featured_media == blank %} bb-pdp__thumb--active{% endif %}"
                data-pdp-thumb
                data-media-index="{{ forloop.index0 }}"
                data-media-id="{{ media.id }}"
                data-image-src="{{ media | image_url: width: 900 }}"
                data-image-srcset="{{ media | image_url: width: 400 }} 400w, {{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
                data-image-alt="{{ media.alt | default: product.title | escape }}"
                data-image-width="{{ media.width }}"
                data-image-height="{{ media.height }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ media | image_url: width: 150 }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  width="72"
                  height="72"
                  loading="lazy"
                >
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="bb-pdp__dots" data-pdp-dots>
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              <button
                type="button"
                class="bb-pdp__dot{% if media.id == current_variant.featured_media.id or forloop.first and current_variant.featured_media == blank %} bb-pdp__dot--active{% endif %}"
                data-pdp-dot
                data-dot-index="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
              ></button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ===== Right column: Buy box with bundle builder ===== {%- endcomment -%}
    <div class="bb-pdp__buybox">
      <h1 class="bb-pdp__title">{{ product.title }}</h1>

      {%- comment -%} Star rating {%- endcomment -%}
      {%- if show_reviews and product.metafields.reviews.rating.value != blank -%}
        {%- assign rating_value = product.metafields.reviews.rating.value.rating -%}
        {%- assign rating_max = product.metafields.reviews.rating.value.scale_max | default: 5 -%}
        {%- assign rating_count = product.metafields.reviews.rating_count | default: 0 -%}
        {%- assign rating_floor = rating_value | floor -%}
        {%- assign rating_decimal = rating_value | minus: rating_floor -%}
        {%- assign rating_half_star = rating_floor | plus: 1 -%}
        {%- assign rating_has_half = false -%}
        {%- if rating_decimal >= 0.3 -%}{%- assign rating_has_half = true -%}{%- endif -%}
        <div class="bb-pdp__rating" data-pdp-rating>
          <div class="bb-pdp__stars" aria-label="{{ rating_value }} out of {{ rating_max }} stars">
            {%- for i in (1..5) -%}
              {%- if i <= rating_floor -%}
                <svg class="bb-pdp__star" width="16" height="16" viewBox="0 0 24 24" fill="#d29b28" stroke="#d29b28" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- elsif i == rating_half_star and rating_has_half -%}
                <svg class="bb-pdp__star" width="16" height="16" viewBox="0 0 24 24" fill="url(#bb-half-{{ section.id }})" stroke="#d29b28" stroke-width="1.5"><defs><linearGradient id="bb-half-{{ section.id }}"><stop offset="50%" stop-color="#d29b28"/><stop offset="50%" stop-color="transparent"/></linearGradient></defs><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- else -%}
                <svg class="bb-pdp__star" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--bb-border);"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if rating_count > 0 -%}
            <span class="bb-pdp__rating-count">({{ rating_count }})</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="bb-pdp__price-row">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="bb-pdp__compare-price" data-pdp-compare-price>{{ current_variant.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="bb-pdp__price" data-pdp-price>{{ current_variant.price | money }}</span>
      </div>

      {%- comment -%} ===== Variant options (Color swatches + Size buttons) ===== {%- endcomment -%}
      {%- if show_variant_selector and product.options.size > 0 and product.variants.size > 1 -%}
        <div class="bb-pdp__options" data-pdp-options>
          {%- for option in product.options_with_values -%}
            {%- assign option_name_down = option.name | downcase -%}
            {%- assign is_color = false -%}
            {%- if option_name_down == 'color' or option_name_down == 'colour' or option_name_down == 'colors' -%}
              {%- assign is_color = true -%}
            {%- endif -%}

            <div class="bb-pdp__option-group" data-option-group data-option-position="{{ option.position }}">
              <label class="bb-pdp__option-label">
                {{ option.name }}{% if is_color %}: <span data-option-selected-name>{{ option.selected_value }}</span>{% endif %}
              </label>

              {%- if is_color -%}
                {%- comment -%} Render color swatches {%- endcomment -%}
                <div class="bb-pdp__swatches">
                  {%- for value in option.values -%}
                    {%- assign color_handle = value | handle -%}
                    <button
                      type="button"
                      class="bb-pdp__swatch{% if option.selected_value == value %} bb-pdp__swatch--active{% endif %}"
                      data-option-value="{{ value | escape }}"
                      data-option-position="{{ option.position }}"
                      title="{{ value }}"
                      aria-label="{{ value }}"
                      {%- if value.swatch.color %}
                      style="--swatch-bg: {{ value.swatch.color }};"
                      {%- endif %}
                    >
                      {%- if value.swatch.image -%}
                        <span class="bb-pdp__swatch-visual" style="background-image: url('{{ value.swatch.image | image_url: width: 50 }}'); background-size: cover;"></span>
                      {%- elsif value.swatch.color -%}
                        <span class="bb-pdp__swatch-visual" style="background-color: {{ value.swatch.color }};"></span>
                      {%- else -%}
                        <span class="bb-pdp__swatch-visual" data-color-handle="{{ color_handle }}"></span>
                      {%- endif -%}
                    </button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                {%- comment -%} Render option buttons (Size, etc.) {%- endcomment -%}
                <div class="bb-pdp__option-buttons">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="bb-pdp__option-btn{% if option.selected_value == value %} bb-pdp__option-btn--active{% endif %}"
                      data-option-value="{{ value | escape }}"
                      data-option-position="{{ option.position }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if show_tier_progress -%}
        <div class="bb-pdp__tier" data-pdp-tier>
          <p class="bb-pdp__tier-label" data-pdp-tier-label>Select items to unlock discounts</p>
          <div class="bb-pdp__tier-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Discount tier progress">
            <div class="bb-pdp__tier-fill" data-pdp-tier-fill></div>
          </div>
          <p class="bb-pdp__tier-hint" data-pdp-tier-hint style="display: none;"></p>
        </div>
      {%- endif -%}

      {%- comment -%} Bundle product selection (compact inline cards) {%- endcomment -%}
      {%- assign product_count = bundle_products | size -%}
      {%- if product_count > 0 -%}
        <div class="bb-pdp__bundle-items" data-pdp-items>
          <h3 class="bb-pdp__bundle-items-title">Build your bundle ({{ min_items }}–{{ max_items }} items)</h3>

          {%- for bp in bundle_products -%}
            {%- assign bv = bp.selected_or_first_available_variant -%}
            {%- assign bp_sold_out = false -%}
            {%- unless bv.available -%}{%- assign bp_sold_out = true -%}{%- endunless -%}

            <div
              class="bb-pdp__bundle-item{% if bp_sold_out %} bb-pdp__bundle-item--disabled{% endif %}"
              data-pdp-bundle-item
              data-product-id="{{ bp.id }}"
              data-variant-id="{{ bv.id }}"
              data-price="{{ bv.price }}"
              data-title="{{ bp.title | escape }}"
              data-available="{{ bv.available }}"
              role="button"
              tabindex="{% if bp_sold_out %}-1{% else %}0{% endif %}"
              aria-pressed="false"
              aria-label="{% if bp_sold_out %}{{ bp.title }} — Sold out{% else %}Add {{ bp.title }} to bundle{% endif %}"
              {% if bp_sold_out %}aria-disabled="true"{% endif %}
            >
              {%- if bp.featured_image -%}
                <img
                  src="{{ bp.featured_image | image_url: width: 96 }}"
                  alt="{{ bp.title | escape }}"
                  class="bb-pdp__bundle-item-image"
                  width="48"
                  height="48"
                  loading="lazy"
                >
              {%- endif -%}
              <div class="bb-pdp__bundle-item-info">
                <div class="bb-pdp__bundle-item-title">{{ bp.title }}</div>
                <div class="bb-pdp__bundle-item-price">
                  {%- if bp_sold_out -%}Sold out{%- else -%}{{ bv.price | money }}{%- endif -%}
                </div>
              </div>
              <div class="bb-pdp__bundle-item-qty" style="display: none;" data-pdp-item-qty>
                <button type="button" data-action="decrease" aria-label="Decrease quantity" disabled>&#8722;</button>
                <span data-pdp-qty-value>1</span>
                <button type="button" data-action="increase" aria-label="Increase quantity">&#43;</button>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="color: var(--bb-text-faded); font-size: 0.95rem;">
          Select products in the theme editor to build your bundle.
        </p>
      {%- endif -%}

      <div class="bb-pdp__savings" hidden data-pdp-savings>You save $0.00!</div>

      <div class="bb-pdp__summary" data-pdp-summary aria-live="polite">
        <div class="bb-pdp__summary-row">
          <span>Items selected</span>
          <span data-pdp-count>0</span>
        </div>
        <div class="bb-pdp__summary-row bb-pdp__summary-row--discount" style="display: none;">
          <span>Bundle discount</span>
          <span data-pdp-discount>-{{ 0 | money }}</span>
        </div>
        <div class="bb-pdp__summary-row bb-pdp__summary-row--total">
          <span>Total</span>
          <span data-pdp-total>{{ 0 | money }}</span>
        </div>
      </div>

      <button type="button" class="bb-pdp__cta" disabled data-pdp-cta>
        {{ cta_text }}
      </button>

      {%- comment -%} Trust badges {%- endcomment -%}
      {%- if show_trust_badges -%}
        <div class="bb-pdp__trust">
          {%- if block.settings.trust_1_text != blank -%}
            <div class="bb-pdp__trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{{ block.settings.trust_1_text }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.trust_2_text != blank -%}
            <div class="bb-pdp__trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              <span>{{ block.settings.trust_2_text }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.trust_3_text != blank -%}
            <div class="bb-pdp__trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              <span>{{ block.settings.trust_3_text }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.trust_4_text != blank -%}
            <div class="bb-pdp__trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span>{{ block.settings.trust_4_text }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Review star callout below ATC {%- endcomment -%}
      {%- if show_reviews and product.metafields.reviews.rating.value != blank -%}
        <div class="bb-pdp__review-callout">
          <div class="bb-pdp__stars bb-pdp__stars--small">
            {%- for i in (1..5) -%}
              {%- if i <= rating_floor -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#d29b28" stroke="#d29b28" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--bb-border);"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="bb-pdp__review-callout-text">
            {{ rating_value }} / {{ rating_max }} based on {{ rating_count }} reviews
          </span>
        </div>
      {%- endif -%}

      {%- comment -%} Accordion: Description, Shipping, Care {%- endcomment -%}
      {%- assign has_accordion = false -%}
      {%- if product.description != blank or block.settings.shipping_info != blank or block.settings.care_info != blank -%}
        {%- assign has_accordion = true -%}
      {%- endif -%}

      {%- if has_accordion -%}
        <div class="bb-pdp__accordion">
          {%- if product.description != blank -%}
            <details class="bb-pdp__accordion-item" open>
              <summary class="bb-pdp__accordion-trigger">
                <span class="bb-pdp__accordion-trigger-inner">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  Description
                </span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">
                {{ product.description }}
              </div>
            </details>
          {%- endif -%}

          {%- if block.settings.shipping_info != blank -%}
            <details class="bb-pdp__accordion-item">
              <summary class="bb-pdp__accordion-trigger">
                <span class="bb-pdp__accordion-trigger-inner">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  Shipping
                </span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">
                {{ block.settings.shipping_info }}
              </div>
            </details>
          {%- endif -%}

          {%- if block.settings.care_info != blank -%}
            <details class="bb-pdp__accordion-item">
              <summary class="bb-pdp__accordion-trigger">
                <span class="bb-pdp__accordion-trigger-inner">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  Care Instructions
                </span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">
                {{ block.settings.care_info }}
              </div>
            </details>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Notification toast {%- endcomment -%}
  <div class="bb-pdp__notification" aria-live="polite" role="status" data-pdp-notification></div>
</div>

<script src="{{ 'bundle-core.js' | asset_url }}" defer></script>
<script src="{{ 'bundle-pdp.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bundle PDP",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "bundle_name",
      "label": "Bundle name",
      "default": "Custom Bundle",
      "info": "Internal name for bundle line item properties"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Bundle products",
      "limit": 12,
      "info": "Products available for the bundle. Displayed as compact cards in the buy box."
    },
    {
      "type": "header",
      "content": "Discount Tiers (fallback)"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Discount type",
      "options": [
        { "value": "percentage", "label": "Percentage off" },
        { "value": "fixed", "label": "Fixed amount off" }
      ],
      "default": "percentage",
      "info": "Overridden by Bundle Builder app config when available."
    },
    {
      "type": "range",
      "id": "discount_2_items",
      "label": "Discount for 2 items",
      "min": 0, "max": 100, "step": 1, "default": 10
    },
    {
      "type": "text",
      "id": "tier_2_label",
      "label": "Tier 2 label",
      "default": "Starter Bundle"
    },
    {
      "type": "range",
      "id": "discount_3_items",
      "label": "Discount for 3 items",
      "min": 0, "max": 100, "step": 1, "default": 15
    },
    {
      "type": "text",
      "id": "tier_3_label",
      "label": "Tier 3 label",
      "default": "Value Bundle"
    },
    {
      "type": "range",
      "id": "discount_4_items",
      "label": "Discount for 4 items",
      "min": 0, "max": 100, "step": 1, "default": 20
    },
    {
      "type": "text",
      "id": "tier_4_label",
      "label": "Tier 4 label",
      "default": "Best Value"
    },
    {
      "type": "range",
      "id": "discount_5_items",
      "label": "Discount for 5+ items",
      "min": 0, "max": 100, "step": 1, "default": 25
    },
    {
      "type": "text",
      "id": "tier_5_label",
      "label": "Tier 5+ label",
      "default": "Ultimate Bundle"
    },
    {
      "type": "range",
      "id": "min_items",
      "label": "Minimum items",
      "min": 1, "max": 8, "step": 1, "default": 2
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum items",
      "min": 2, "max": 20, "step": 1, "default": 8
    },
    {
      "type": "header",
      "content": "Display Options"
    },
    {
      "type": "checkbox",
      "id": "show_variant_selector",
      "label": "Show variant selector (color/size)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show savings callout",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tier_progress",
      "label": "Show tier progress bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show review rating",
      "default": true,
      "info": "Displays star rating from product review metafields"
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_1_text",
      "label": "Trust badge 1 (shipping icon)",
      "default": "Free shipping over $100"
    },
    {
      "type": "text",
      "id": "trust_2_text",
      "label": "Trust badge 2 (returns icon)",
      "default": "30-day easy returns"
    },
    {
      "type": "text",
      "id": "trust_3_text",
      "label": "Trust badge 3 (quality icon)",
      "default": "Premium quality guaranteed"
    },
    {
      "type": "text",
      "id": "trust_4_text",
      "label": "Trust badge 4 (support icon)"
    },
    {
      "type": "header",
      "content": "Accordion Content"
    },
    {
      "type": "richtext",
      "id": "shipping_info",
      "label": "Shipping information",
      "default": "<p>We offer free standard shipping on all orders over $100. Orders are processed within 1-2 business days and typically arrive within 5-7 business days.</p>"
    },
    {
      "type": "richtext",
      "id": "care_info",
      "label": "Care instructions",
      "default": "<p>Machine wash cold with like colors. Tumble dry low. Do not bleach. Iron on low heat if needed.</p>"
    },
    {
      "type": "header",
      "content": "Button & Behavior"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "checkbox",
      "id": "cart_redirect",
      "label": "Redirect to cart after adding",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#182f5c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 100, "step": 4, "default": 48, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 100, "step": 4, "default": 48, "unit": "px"
    }
  ]
}
{% endschema %}
