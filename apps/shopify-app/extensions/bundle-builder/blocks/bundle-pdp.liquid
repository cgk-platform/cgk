{{ 'bundle-pdp.css' | asset_url | stylesheet_tag }}

{%- comment -%} Read bundle config from app metafield {%- endcomment -%}
{%- assign metafield_config_raw = app.metafields["bundle-discount"]["config"].value -%}
{%- assign has_metafield_config = false -%}
{%- if metafield_config_raw != blank -%}
  {%- assign has_metafield_config = true -%}
{%- endif -%}

{%- liquid
  assign cta_text = block.settings.cta_text | default: 'Add Bundle to Cart'
  assign show_savings = block.settings.show_savings
  assign show_tier_progress = block.settings.show_tier_progress
  assign cart_redirect = block.settings.cart_redirect
  assign accent_color = block.settings.accent_color | default: '#182f5c'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
  assign bundle_name = block.settings.bundle_name | default: 'Custom Bundle'
  assign min_items = block.settings.min_items
  assign max_items = block.settings.max_items
  assign show_variant_selector = block.settings.show_variant_selector
-%}

{%- if has_metafield_config -%}
  {%- assign tiers_json = '[]' -%}
  {%- assign discount_type = 'percentage' -%}
  {%- assign bundle_id_attr = '' -%}
{%- else -%}
  {%- assign discount_type = block.settings.discount_type | default: 'percentage' -%}
  {%- assign bundle_id_attr = block.id -%}
  {%- capture tiers_json -%}
[
  {%- assign tier_count = 0 -%}
  {%- if block.settings.discount_2_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":{{ block.settings.discount_2_items }},"discount":{{ block.settings.discount_2_items }},"label":{{ block.settings.tier_2_label | default: '' | json }},"reward":{{ block.settings.tier_2_reward | default: '' | json }},"giftImage":{{ block.settings.tier_2_gift_image | default: '' | json }},"valueBadge":{{ block.settings.tier_2_value_badge | default: '' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_3_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":{{ block.settings.discount_3_items }},"discount":{{ block.settings.discount_3_items }},"label":{{ block.settings.tier_3_label | default: '' | json }},"reward":{{ block.settings.tier_3_reward | default: '' | json }},"giftImage":{{ block.settings.tier_3_gift_image | default: '' | json }},"valueBadge":{{ block.settings.tier_3_value_badge | default: '' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_4_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":{{ block.settings.discount_4_items }},"discount":{{ block.settings.discount_4_items }},"label":{{ block.settings.tier_4_label | default: '' | json }},"reward":{{ block.settings.tier_4_reward | default: '' | json }},"giftImage":{{ block.settings.tier_4_gift_image | default: '' | json }},"valueBadge":{{ block.settings.tier_4_value_badge | default: '' | json }}}
    {%- assign tier_count = tier_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.discount_5_items > 0 -%}
    {%- if tier_count > 0 -%},{%- endif -%}
    {"count":{{ block.settings.discount_5_items }},"discount":{{ block.settings.discount_5_items }},"label":{{ block.settings.tier_5_label | default: '' | json }},"reward":{{ block.settings.tier_5_reward | default: '' | json }},"giftImage":{{ block.settings.tier_5_gift_image | default: '' | json }},"valueBadge":{{ block.settings.tier_5_value_badge | default: '' | json }}}
  {%- endif -%}
]
  {%- endcapture -%}
{%- endif -%}

{%- assign bundle_products = block.settings.products -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} Determine selected color for media filtering {%- endcomment -%}
{%- assign selected_color = '' -%}
{%- for option in product.options_with_values -%}
  {%- assign opt_down = option.name | downcase -%}
  {%- if opt_down == 'color' or opt_down == 'colour' or opt_down == 'colors' -%}
    {%- assign selected_color = option.selected_value -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Build variant JSON {%- endcomment -%}
{%- capture variants_json -%}
[
  {%- for variant in product.variants -%}
    {%- if forloop.index > 1 -%},{%- endif -%}
    {
      "id":{{ variant.id }},
      "available":{{ variant.available }},
      "price":{{ variant.price }},
      "compare_at_price":{{ variant.compare_at_price | default: 'null' }},
      "options":{{ variant.options | json }},
      "featured_media_id":{{ variant.featured_media.id | default: 'null' }}
    }
  {%- endfor -%}
]
{%- endcapture -%}

{%- comment -%} Media color filtering — match theme's exact `where: 'alt', image_color_name` logic {%- endcomment -%}
{%- assign title_prefix = product.title | append: ' - ' -%}
{%- assign image_color_name = product.title -%}
{%- if selected_color != blank -%}
  {%- assign image_color_name = product.title | append: ' - ' | append: selected_color -%}
{%- endif -%}
{%- assign color_medias = product.media | where: 'alt', image_color_name -%}
{%- assign has_color_media = false -%}
{%- if color_medias != blank and selected_color != blank -%}
  {%- assign has_color_media = true -%}
{%- endif -%}

{%- comment -%} Capture icon HTML (reused in desktop and mobile) {%- endcomment -%}
{%- capture icons_html -%}
  {%- if block.settings.icon_1_image != blank -%}
    <div class="bb-pdp__icon-item">
      <img src="{{ block.settings.icon_1_image | image_url: width: 200 }}" alt="{{ block.settings.icon_1_label | default: '' | escape }}" loading="lazy" width="97" height="97">
      {%- if block.settings.icon_1_label != blank -%}<span>{{ block.settings.icon_1_label }}</span>{%- endif -%}
    </div>
  {%- endif -%}
  {%- if block.settings.icon_2_image != blank -%}
    <div class="bb-pdp__icon-item">
      <img src="{{ block.settings.icon_2_image | image_url: width: 200 }}" alt="{{ block.settings.icon_2_label | default: '' | escape }}" loading="lazy" width="97" height="97">
      {%- if block.settings.icon_2_label != blank -%}<span>{{ block.settings.icon_2_label }}</span>{%- endif -%}
    </div>
  {%- endif -%}
  {%- if block.settings.icon_3_image != blank -%}
    <div class="bb-pdp__icon-item">
      <img src="{{ block.settings.icon_3_image | image_url: width: 200 }}" alt="{{ block.settings.icon_3_label | default: '' | escape }}" loading="lazy" width="97" height="97">
      {%- if block.settings.icon_3_label != blank -%}<span>{{ block.settings.icon_3_label }}</span>{%- endif -%}
    </div>
  {%- endif -%}
  {%- if block.settings.icon_4_image != blank -%}
    <div class="bb-pdp__icon-item">
      <img src="{{ block.settings.icon_4_image | image_url: width: 200 }}" alt="{{ block.settings.icon_4_label | default: '' | escape }}" loading="lazy" width="97" height="97">
      {%- if block.settings.icon_4_label != blank -%}<span>{{ block.settings.icon_4_label }}</span>{%- endif -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- comment -%} Capture tab content for reuse {%- endcomment -%}
{%- assign tab_count = 0 -%}
{%- capture tabs_buttons_html -%}
  {%- if product.description != blank -%}
    <button class="bb-pdp__tab-btn{% if tab_count == 0 %} bb-pdp__tab-btn--active{% endif %}" data-tab-target="bb-tab-desc-{{ block.id }}" type="button">Description</button>
    {%- assign tab_count = tab_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.size_guide != blank -%}
    <button class="bb-pdp__tab-btn{% if tab_count == 0 %} bb-pdp__tab-btn--active{% endif %}" data-tab-target="bb-tab-size-{{ block.id }}" type="button">Size</button>
    {%- assign tab_count = tab_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.shipping_info != blank -%}
    <button class="bb-pdp__tab-btn{% if tab_count == 0 %} bb-pdp__tab-btn--active{% endif %}" data-tab-target="bb-tab-ship-{{ block.id }}" type="button">Shipping</button>
    {%- assign tab_count = tab_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.care_info != blank -%}
    <button class="bb-pdp__tab-btn{% if tab_count == 0 %} bb-pdp__tab-btn--active{% endif %}" data-tab-target="bb-tab-care-{{ block.id }}" type="button">Care</button>
    {%- assign tab_count = tab_count | plus: 1 -%}
  {%- endif -%}
{%- endcapture -%}

{%- assign tab_idx = 0 -%}
{%- capture tabs_content_html -%}
  {%- if product.description != blank -%}
    <div class="bb-pdp__tab-panel{% if tab_idx == 0 %} bb-pdp__tab-panel--active{% endif %}" id="bb-tab-desc-{{ block.id }}">{{ product.description }}</div>
    {%- assign tab_idx = tab_idx | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.size_guide != blank -%}
    <div class="bb-pdp__tab-panel{% if tab_idx == 0 %} bb-pdp__tab-panel--active{% endif %}" id="bb-tab-size-{{ block.id }}">{{ block.settings.size_guide }}</div>
    {%- assign tab_idx = tab_idx | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.shipping_info != blank -%}
    <div class="bb-pdp__tab-panel{% if tab_idx == 0 %} bb-pdp__tab-panel--active{% endif %}" id="bb-tab-ship-{{ block.id }}">{{ block.settings.shipping_info }}</div>
    {%- assign tab_idx = tab_idx | plus: 1 -%}
  {%- endif -%}
  {%- if block.settings.care_info != blank -%}
    <div class="bb-pdp__tab-panel{% if tab_idx == 0 %} bb-pdp__tab-panel--active{% endif %}" id="bb-tab-care-{{ block.id }}">{{ block.settings.care_info }}</div>
    {%- assign tab_idx = tab_idx | plus: 1 -%}
  {%- endif -%}
{%- endcapture -%}

{%- assign has_tabs = false -%}
{%- if tab_count > 0 -%}{%- assign has_tabs = true -%}{%- endif -%}
{%- assign has_icons = false -%}
{%- if icons_html != blank -%}{%- assign has_icons = true -%}{%- endif -%}

<div data-bundle-pdp-wrapper>
<div
  class="bb-pdp"
  data-bundle-pdp
  data-section-id="{{ section.id }}"
  data-block-id="{{ block.id }}"
  data-discount-type="{{ discount_type }}"
  data-min-items="{{ min_items }}"
  data-max-items="{{ max_items }}"
  data-show-savings="{{ show_savings }}"
  data-show-tier-progress="{{ show_tier_progress }}"
  data-bundle-name="{{ bundle_name | escape }}"
  data-cta-text="{{ cta_text | escape }}"
  data-cart-redirect="{{ cart_redirect }}"
  data-tiers="{{ tiers_json | strip_newlines | escape }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-product-url="{{ product.url }}"
  data-product-title="{{ product.title | escape }}"
  {%- if has_metafield_config %}
  data-metafield-config="{{ metafield_config_raw | escape }}"
  {%- endif -%}
  {%- if bundle_id_attr != blank %}
  data-bundle-id="{{ bundle_id_attr }}"
  {%- endif -%}
  {{ block.shopify_attributes }}
  style="--bb-accent-color: {{ accent_color }}; --bb-btn-text-color: {{ button_text_color }};"
>
  <script type="application/json" data-pdp-variants>{{ variants_json | strip_newlines }}</script>

  <div class="bb-pdp__layout">
    {%- comment -%} ===== GALLERY COLUMN ===== {%- endcomment -%}
    <div class="bb-pdp__gallery-col">
      <div class="bb-pdp__gallery" data-gallery>
        <div class="bb-pdp__gallery-inner">
          {%- comment -%} Thumbnails {%- endcomment -%}
          <div class="bb-pdp__thumbs" data-gallery-thumbs>
            <div class="bb-pdp__thumbs-track">
              {%- for media in product.media -%}
                {%- assign media_color = '' -%}
                {%- if media.alt != blank -%}
                  {%- assign stripped_alt = media.alt | remove_first: title_prefix -%}
                  {%- if stripped_alt != media.alt and stripped_alt != blank -%}
                    {%- assign media_color = stripped_alt -%}
                  {%- endif -%}
                {%- endif -%}
                {%- comment -%} Theme logic: if color media exist, ONLY show matching. Otherwise show all. {%- endcomment -%}
                {%- assign show_media = true -%}
                {%- if has_color_media -%}
                  {%- if media.alt != image_color_name -%}
                    {%- assign show_media = false -%}
                  {%- endif -%}
                {%- endif -%}
                <button
                  class="bb-pdp__thumb"
                  type="button"
                  data-thumb-index="{{ forloop.index0 }}"
                  data-media-color="{{ media_color | escape }}"
                  {% unless show_media %}style="display:none"{% endunless %}
                  aria-label="View image {{ forloop.index }}"
                >
                  <img
                    src="{{ media | image_url: width: 150, crop: 'center' }}"
                    alt=""
                    width="64"
                    height="64"
                    loading="lazy"
                  >
                </button>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} Main slider {%- endcomment -%}
          <div class="bb-pdp__slider-wrap">
            <div class="bb-pdp__slider" data-gallery-slider>
              {%- for media in product.media -%}
                {%- assign media_color = '' -%}
                {%- if media.alt != blank -%}
                  {%- assign stripped_alt = media.alt | remove_first: title_prefix -%}
                  {%- if stripped_alt != media.alt and stripped_alt != blank -%}
                    {%- assign media_color = stripped_alt -%}
                  {%- endif -%}
                {%- endif -%}
                {%- assign show_media = true -%}
                {%- if has_color_media -%}
                  {%- if media.alt != image_color_name -%}
                    {%- assign show_media = false -%}
                  {%- endif -%}
                {%- endif -%}
                <div
                  class="bb-pdp__slide"
                  data-slide-index="{{ forloop.index0 }}"
                  data-media-color="{{ media_color | escape }}"
                  {% unless show_media %}style="display:none"{% endunless %}
                >
                  <img
                    src="{{ media | image_url: width: 1200 }}"
                    alt="{{ media.alt | escape }}"
                    width="{{ media.width | default: 800 }}"
                    height="{{ media.height | default: 849 }}"
                    loading="{% if forloop.first and show_media %}eager{% else %}lazy{% endif %}"
                  >
                </div>
              {%- endfor -%}
            </div>

            {%- comment -%} Navigation arrows {%- endcomment -%}
            <button class="bb-pdp__arrow bb-pdp__arrow--prev" type="button" data-gallery-prev aria-label="Previous image">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="12" viewBox="0 0 18 12" fill="none">
                <path d="M0.22 6.054C-0.073 5.76-0.073 5.286 0.22 4.993L4.993 0.22C5.286-0.073 5.76-0.073 6.053 0.22C6.346 0.513 6.346 0.988 6.053 1.28L1.81 5.524L6.053 9.766C6.346 10.06 6.346 10.534 6.053 10.827C5.76 11.12 5.286 11.12 4.993 10.827L0.22 6.054ZM16.75 4.774C17.164 4.774 17.5 5.11 17.5 5.524C17.5 5.938 17.164 6.274 16.75 6.274V4.774ZM0.75 4.774H16.75V6.274H0.75V4.774Z" fill="#1F3D77"/>
              </svg>
            </button>
            <button class="bb-pdp__arrow bb-pdp__arrow--next" type="button" data-gallery-next aria-label="Next image">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="12" viewBox="0 0 18 12" fill="none">
                <path d="M17.28 6.054C17.573 5.76 17.573 5.286 17.28 4.993L12.507 0.22C12.214-0.073 11.74-0.073 11.447 0.22C11.154 0.513 11.154 0.988 11.447 1.28L15.69 5.524L11.447 9.766C11.154 10.06 11.154 10.534 11.447 10.827C11.74 11.12 12.214 11.12 12.507 10.827L17.28 6.054ZM0.75 4.774C0.336 4.774 0 5.11 0 5.524C0 5.938 0.336 6.274 0.75 6.274V4.774ZM16.75 4.774H0.75V6.274H16.75V4.774Z" fill="#1F3D77"/>
              </svg>
            </button>

            {%- comment -%} Product badges {%- endcomment -%}
            {%- assign badges = product.metafields.custom.badges.value -%}
            {%- if badges != blank -%}
              <div class="bb-pdp__badges">
                {%- for badge in badges -%}
                  <span class="bb-pdp__badge" style="background:{{ badge.color_background }};color:{{ badge.color_text }};">{{ badge.name }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- comment -%} Desktop: product tabs {%- endcomment -%}
      {%- if has_tabs -%}
        <div class="bb-pdp__tabs bb-pdp__desktop-only" data-pdp-tabs>
          <div class="bb-pdp__tabs-buttons">{{ tabs_buttons_html }}</div>
          {{ tabs_content_html }}
        </div>
      {%- endif -%}

      {%- comment -%} Desktop: icon row {%- endcomment -%}
      {%- if has_icons -%}
        <div class="bb-pdp__icons bb-pdp__desktop-only">{{ icons_html }}</div>
      {%- endif -%}
    </div>

    {%- comment -%} ===== INFO COLUMN ===== {%- endcomment -%}
    <div class="bb-pdp__info-col">

      {%- comment -%} 1. Title {%- endcomment -%}
      <h1 class="bb-pdp__title">{{ product.title | escape }}</h1>

      {%- comment -%} 2. Rating {%- endcomment -%}
      {%- if product.metafields.reviews.rating.value != blank -%}
        {%- assign rating_value = product.metafields.reviews.rating.value.rating -%}
        {%- assign rating_max = product.metafields.reviews.rating.value.scale_max -%}
        {%- assign rating_count = product.metafields.reviews.rating_count -%}
        <div class="bb-pdp__rating">
          <div class="bb-pdp__rating-stars" style="--rating: {{ rating_value }};" role="img" aria-label="{{ rating_value }} out of {{ rating_max }}"></div>
          <span class="bb-pdp__rating-count">{{ rating_count }} {% if rating_count == 1 %}Review{% else %}Reviews{% endif %}</span>
        </div>
      {%- endif -%}

      {%- comment -%} 3. Tagline {%- endcomment -%}
      {%- if block.settings.tagline_text != blank -%}
        <p class="bb-pdp__tagline" style="background-color:{{ block.settings.tagline_bg | default: '#d7e7f3' }};border-radius:{{ block.settings.tagline_border_radius | default: 50 }}px;">
          {{- block.settings.tagline_text -}}
        </p>
      {%- endif -%}

      {%- comment -%} 4. Price {%- endcomment -%}
      <div class="bb-pdp__price-wrap{% if current_variant.compare_at_price > current_variant.price %} bb-pdp__price-wrap--sale{% endif %}" data-pdp-price>
        <span class="bb-pdp__price" data-pdp-price-regular>{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="bb-pdp__price-compare" data-pdp-price-compare>{{ current_variant.compare_at_price | money }}</span>
          {%- assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="bb-pdp__price-badge" data-pdp-price-badge>{{ discount_pct }}% Off</span>
        {%- else -%}
          <span class="bb-pdp__price-compare" data-pdp-price-compare style="display:none"></span>
          <span class="bb-pdp__price-badge" data-pdp-price-badge style="display:none"></span>
        {%- endif -%}
      </div>

      {%- comment -%} 5. Shipping callout {%- endcomment -%}
      {%- if block.settings.shipping_callout != blank -%}
        <p class="bb-pdp__shipping">{{ block.settings.shipping_callout }}</p>
      {%- endif -%}

      {%- comment -%} 6. Variant picker {%- endcomment -%}
      {%- if show_variant_selector and product.options.size > 0 and product.variants.size > 1 -%}
        <div class="bb-pdp__options" data-pdp-options>
          {%- for option in product.options_with_values -%}
            {%- assign option_name_down = option.name | downcase -%}
            {%- assign is_color = false -%}
            {%- if option_name_down == 'color' or option_name_down == 'colour' or option_name_down == 'colors' -%}
              {%- assign is_color = true -%}
            {%- endif -%}
            {%- assign is_size = false -%}
            {%- if option_name_down == 'size' -%}
              {%- assign is_size = true -%}
            {%- endif -%}

            <div class="bb-pdp__option-group" data-option-group data-option-position="{{ option.position }}" data-option-name="{{ option_name_down }}">
              <label class="bb-pdp__option-label">
                {{ option.name }}: <span data-option-selected-name>{{ option.selected_value }}</span>
              </label>

              {%- if is_color -%}
                <div class="bb-pdp__swatches">
                  {%- for value in option.values -%}
                    {%- assign color_handle = value | handle -%}
                    {%- assign swatch_style = '' -%}
                    {%- if value.swatch.image -%}
                      {%- assign swatch_style = 'background-image: url(' | append: value.swatch.image | image_url: width: 80 | prepend: "'" | append: "'" | append: '); background-size: cover;' -%}
                    {%- elsif value.swatch.color -%}
                      {%- assign swatch_style = 'background-color: ' | append: value.swatch.color | append: ';' -%}
                    {%- else -%}
                      {%- assign meta_swatch = metaobjects['shopify--color-pattern'][color_handle] -%}
                      {%- if meta_swatch.image -%}
                        {%- assign swatch_style = 'background-image: url(' | append: meta_swatch.image | image_url: width: 80 | prepend: "'" | append: "'" | append: '); background-size: cover;' -%}
                      {%- elsif meta_swatch.color -%}
                        {%- assign swatch_style = 'background-color: ' | append: meta_swatch.color | append: ';' -%}
                      {%- endif -%}
                    {%- endif -%}
                    <button
                      type="button"
                      class="bb-pdp__swatch{% if option.selected_value == value %} bb-pdp__swatch--active{% endif %}{% unless value.available %} bb-pdp__swatch--unavailable{% endunless %}"
                      data-option-value="{{ value | escape }}"
                      data-option-position="{{ option.position }}"
                      title="{{ value }}"
                      aria-label="{{ value }}"
                    >
                      <span class="bb-pdp__swatch-visual"{% if swatch_style != '' %} style="{{ swatch_style }}"{% endif %} data-color-handle="{{ color_handle }}"></span>
                    </button>
                  {%- endfor -%}
                </div>

              {%- elsif is_size -%}
                {%- comment -%} Desktop: selectlike dropdown {%- endcomment -%}
                <div class="bb-pdp__selectlike bb-pdp__desktop-only" data-selectlike>
                  <button type="button" class="bb-pdp__selectlike-trigger" data-selectlike-trigger>
                    <span class="bb-pdp__selectlike-value" data-selectlike-value>{{ option.selected_value }}</span>
                    <span class="bb-pdp__selectlike-chev">
                      <svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </button>
                  <div class="bb-pdp__selectlike-menu" data-selectlike-menu>
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="bb-pdp__selectlike-option{% if option.selected_value == value %} bb-pdp__selectlike-option--active{% endif %}{% unless value.available %} bb-pdp__selectlike-option--unavailable{% endunless %}"
                        data-option-value="{{ value | escape }}"
                        data-option-position="{{ option.position }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>

                {%- comment -%} Mobile: pill buttons {%- endcomment -%}
                <div class="bb-pdp__size-pills bb-pdp__mobile-only">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="bb-pdp__size-pill{% if option.selected_value == value %} bb-pdp__size-pill--active{% endif %}{% unless value.available %} bb-pdp__size-pill--unavailable{% endunless %}"
                      data-option-value="{{ value | escape }}"
                      data-option-position="{{ option.position }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>

              {%- else -%}
                {%- comment -%} Generic option buttons {%- endcomment -%}
                <div class="bb-pdp__option-buttons">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="bb-pdp__option-btn{% if option.selected_value == value %} bb-pdp__option-btn--active{% endif %}{% unless value.available %} bb-pdp__option-btn--unavailable{% endunless %}"
                      data-option-value="{{ value | escape }}"
                      data-option-position="{{ option.position }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} === BUNDLE BUILDER === {%- endcomment -%}

      {%- comment -%} 7. Tier progress — Rawdog-style milestone bar + reward cards {%- endcomment -%}
      {%- if show_tier_progress -%}
        <div class="bb-pdp__tier" data-pdp-tier>
          {%- comment -%} Progress message {%- endcomment -%}
          <p class="bb-pdp__tier-label" data-pdp-tier-label>Add products to unlock free gifts</p>

          {%- comment -%} Milestone progress bar {%- endcomment -%}
          <div class="bb-pdp__tier-bar" data-pdp-tier-bar>
            <div class="bb-pdp__tier-bar-bg"></div>
            <div class="bb-pdp__tier-bar-fill" data-pdp-tier-fill></div>
            {%- comment -%} Milestone dots rendered by JS based on tier count {%- endcomment -%}
            <div class="bb-pdp__tier-dots" data-pdp-tier-dots></div>
          </div>

          {%- comment -%} Reward tier cards {%- endcomment -%}
          <div class="bb-pdp__tier-cards" data-pdp-tier-cards>
            {%- comment -%} Cards rendered by JS from tier data {%- endcomment -%}
          </div>

          {%- comment -%} Unlocked rewards callout {%- endcomment -%}
          <div class="bb-pdp__tier-callout" data-pdp-tier-callout style="display:none;">
            <svg class="bb-pdp__tier-callout-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12v10H4V12"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
            <span data-pdp-tier-callout-text></span>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} 8. Bundle items {%- endcomment -%}
      {%- assign product_count = bundle_products | size -%}
      {%- if product_count > 0 -%}
        <div class="bb-pdp__bundle-items" data-pdp-items>
          <h3 class="bb-pdp__bundle-items-title">Build your bundle ({{ min_items }}–{{ max_items }} items)</h3>

          {%- for bp in bundle_products -%}
            {%- assign bv = bp.selected_or_first_available_variant -%}
            {%- assign bp_sold_out = false -%}
            {%- unless bv.available -%}{%- assign bp_sold_out = true -%}{%- endunless -%}
            {%- assign bp_has_variants = false -%}
            {%- if bp.variants.size > 1 -%}{%- assign bp_has_variants = true -%}{%- endif -%}

            {%- if bp_has_variants -%}
              {%- capture bp_variants_json -%}
              [{%- for bpv in bp.variants -%}{%- if forloop.index > 1 -%},{%- endif -%}{"id":{{ bpv.id }},"available":{{ bpv.available }},"price":{{ bpv.price }},"options":{{ bpv.options | json }},"image":"{{ bpv.featured_image | default: bp.featured_image | image_url: width: 96, crop: 'center' }}"}{%- endfor -%}]
              {%- endcapture -%}
            {%- endif -%}

            <div
              class="bb-pdp__bundle-item{% if bp_sold_out %} bb-pdp__bundle-item--disabled{% endif %}"
              data-pdp-bundle-item
              data-product-id="{{ bp.id }}"
              data-variant-id="{{ bv.id }}"
              data-price="{{ bv.price }}"
              data-title="{{ bp.title | escape }}"
              data-available="{{ bv.available }}"
              {%- if bp_has_variants %} data-has-variants="true"{% endif %}
              role="button"
              tabindex="{% if bp_sold_out %}-1{% else %}0{% endif %}"
              aria-pressed="false"
              aria-label="{% if bp_sold_out %}{{ bp.title }} — Sold out{% else %}Add {{ bp.title }} to bundle{% endif %}"
              {% if bp_sold_out %}aria-disabled="true"{% endif %}
            >
              {%- if bp_has_variants -%}
                <script type="application/json" data-item-variants>{{ bp_variants_json | strip_newlines }}</script>
              {%- endif -%}

              <div class="bb-pdp__bundle-item-top">
                {%- if bp.featured_image -%}
                  <img
                    src="{{ bp.featured_image | image_url: width: 96, crop: 'center' }}"
                    alt="{{ bp.title | escape }}"
                    class="bb-pdp__bundle-item-image"
                    width="48"
                    height="48"
                    loading="lazy"
                    data-item-image
                  >
                {%- endif -%}
                <div class="bb-pdp__bundle-item-info">
                  <div class="bb-pdp__bundle-item-title">{{ bp.title }}</div>
                  <div class="bb-pdp__bundle-item-price" data-item-price>
                    {%- if bp_sold_out -%}Sold out{%- else -%}{{ bv.price | money }}{%- endif -%}
                  </div>
                </div>
                <div class="bb-pdp__bundle-item-qty" style="display: none;" data-pdp-item-qty>
                  <button type="button" data-action="decrease" aria-label="Decrease quantity" disabled>&#8722;</button>
                  <span data-pdp-qty-value>1</span>
                  <button type="button" data-action="increase" aria-label="Increase quantity">&#43;</button>
                </div>
              </div>

              {%- if bp_has_variants -%}
                <div class="bb-pdp__item-options" data-item-options>
                  {%- for bp_option in bp.options_with_values -%}
                    {%- assign bp_opt_down = bp_option.name | downcase -%}
                    {%- assign bp_is_color = false -%}
                    {%- if bp_opt_down == 'color' or bp_opt_down == 'colour' or bp_opt_down == 'colors' -%}
                      {%- assign bp_is_color = true -%}
                    {%- endif -%}

                    <div class="bb-pdp__item-option-group" data-item-option-group data-item-option-position="{{ bp_option.position }}">
                      {%- if bp_is_color -%}
                        <div class="bb-pdp__item-swatches">
                          {%- for val in bp_option.values -%}
                            {%- assign bp_color_handle = val | handle -%}
                            {%- assign bp_swatch_style = '' -%}
                            {%- if val.swatch.image -%}
                              {%- assign bp_swatch_style = 'background-image: url(' | append: val.swatch.image | image_url: width: 36 | prepend: "'" | append: "'" | append: '); background-size: cover;' -%}
                            {%- elsif val.swatch.color -%}
                              {%- assign bp_swatch_style = 'background-color: ' | append: val.swatch.color | append: ';' -%}
                            {%- else -%}
                              {%- assign bp_meta_swatch = metaobjects['shopify--color-pattern'][bp_color_handle] -%}
                              {%- if bp_meta_swatch.image -%}
                                {%- assign bp_swatch_style = 'background-image: url(' | append: bp_meta_swatch.image | image_url: width: 36 | prepend: "'" | append: "'" | append: '); background-size: cover;' -%}
                              {%- elsif bp_meta_swatch.color -%}
                                {%- assign bp_swatch_style = 'background-color: ' | append: bp_meta_swatch.color | append: ';' -%}
                              {%- endif -%}
                            {%- endif -%}
                            <button
                              type="button"
                              class="bb-pdp__item-swatch{% if bp_option.selected_value == val %} bb-pdp__item-swatch--active{% endif %}"
                              data-item-option-value="{{ val | escape }}"
                              data-item-option-position="{{ bp_option.position }}"
                              title="{{ val }}"
                              aria-label="{{ val }}"
                            >
                              <span class="bb-pdp__item-swatch-visual"{% if bp_swatch_style != '' %} style="{{ bp_swatch_style }}"{% endif %} data-color-handle="{{ bp_color_handle }}"></span>
                            </button>
                          {%- endfor -%}
                        </div>
                      {%- else -%}
                        <div class="bb-pdp__item-pills">
                          {%- for val in bp_option.values -%}
                            <button
                              type="button"
                              class="bb-pdp__item-pill{% if bp_option.selected_value == val %} bb-pdp__item-pill--active{% endif %}"
                              data-item-option-value="{{ val | escape }}"
                              data-item-option-position="{{ bp_option.position }}"
                            >
                              {{ val }}
                            </button>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="bb-pdp__empty-msg">Select products in the theme editor to build your bundle.</p>
      {%- endif -%}

      {%- comment -%} 9. Savings + Summary + CTA {%- endcomment -%}
      <div class="bb-pdp__savings" hidden data-pdp-savings>You save $0.00!</div>

      <div class="bb-pdp__summary" data-pdp-summary aria-live="polite">
        <div class="bb-pdp__summary-row">
          <span>Items selected</span>
          <span data-pdp-count>0</span>
        </div>
        <div class="bb-pdp__summary-row bb-pdp__summary-row--discount" style="display: none;">
          <span>Bundle discount</span>
          <span data-pdp-discount>-{{ 0 | money }}</span>
        </div>
        <div class="bb-pdp__summary-row bb-pdp__summary-row--total">
          <span>Total</span>
          <span data-pdp-total>{{ 0 | money }}</span>
        </div>
      </div>

      <button type="button" class="bb-pdp__cta" disabled data-pdp-cta>{{ cta_text }}</button>

      {%- comment -%} 10. Testimonial {%- endcomment -%}
      {%- if block.settings.show_testimonial -%}
        <div class="bb-pdp__testimonial">
          <div class="bb-pdp__testimonial-card">
            <div class="bb-pdp__testimonial-stars" style="--rating: {{ block.settings.testimonial_rating | default: 5 }};"></div>
            <blockquote class="bb-pdp__testimonial-quote">{{ block.settings.testimonial_quote }}</blockquote>
            <div class="bb-pdp__testimonial-author">{{ block.settings.testimonial_author }}</div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} 11. Icons (mobile) {%- endcomment -%}
      {%- if has_icons -%}
        <div class="bb-pdp__icons bb-pdp__mobile-only">{{ icons_html }}</div>
      {%- endif -%}

      {%- comment -%} 12. Accordion (mobile) {%- endcomment -%}
      {%- if has_tabs -%}
        <div class="bb-pdp__accordion bb-pdp__mobile-only">
          {%- if product.description != blank -%}
            <details class="bb-pdp__accordion-item">
              <summary class="bb-pdp__accordion-trigger">
                <span>Description</span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">{{ product.description }}</div>
            </details>
          {%- endif -%}
          {%- if block.settings.size_guide != blank -%}
            <details class="bb-pdp__accordion-item">
              <summary class="bb-pdp__accordion-trigger">
                <span>Size</span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">{{ block.settings.size_guide }}</div>
            </details>
          {%- endif -%}
          {%- if block.settings.shipping_info != blank -%}
            <details class="bb-pdp__accordion-item">
              <summary class="bb-pdp__accordion-trigger">
                <span>Shipping</span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">{{ block.settings.shipping_info }}</div>
            </details>
          {%- endif -%}
          {%- if block.settings.care_info != blank -%}
            <details class="bb-pdp__accordion-item">
              <summary class="bb-pdp__accordion-trigger">
                <span>Care</span>
                <svg class="bb-pdp__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="bb-pdp__accordion-content">{{ block.settings.care_info }}</div>
            </details>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  <div class="bb-pdp__notification" aria-live="polite" role="status" data-pdp-notification></div>
</div>
</div>

<script src="{{ 'bundle-core.js' | asset_url }}" defer></script>
<script src="{{ 'bundle-pdp.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bundle PDP",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "tagline_text",
      "label": "Tagline text",
      "default": "<em>The Internet's Favorite Sheets</em>"
    },
    {
      "type": "color",
      "id": "tagline_bg",
      "label": "Tagline background",
      "default": "#d7e7f3"
    },
    {
      "type": "range",
      "id": "tagline_border_radius",
      "label": "Tagline border radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 50
    },
    {
      "type": "text",
      "id": "shipping_callout",
      "label": "Shipping callout",
      "default": "FREE 3-DAY DELIVERY FOR ORDERS OVER $50"
    },
    {
      "type": "header",
      "content": "Testimonial"
    },
    {
      "type": "checkbox",
      "id": "show_testimonial",
      "label": "Show testimonial",
      "default": true
    },
    {
      "type": "range",
      "id": "testimonial_rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "richtext",
      "id": "testimonial_quote",
      "label": "Quote",
      "default": "<p>They're like wrapping yourself in a cloud made of unicorn fluff and happiness.</p>"
    },
    {
      "type": "text",
      "id": "testimonial_author",
      "label": "Author",
      "default": "-Guy and Brandy"
    },
    {
      "type": "header",
      "content": "Bundle Settings"
    },
    {
      "type": "text",
      "id": "bundle_name",
      "label": "Bundle name",
      "default": "Custom Bundle",
      "info": "Internal name for bundle line item properties"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Bundle products",
      "limit": 12,
      "info": "Products available for the bundle"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Discount type",
      "options": [
        { "value": "percentage", "label": "Percentage off" },
        { "value": "fixed", "label": "Fixed amount off" }
      ],
      "default": "percentage",
      "info": "Overridden by Bundle Builder app config when available."
    },
    {
      "type": "range",
      "id": "discount_2_items",
      "label": "Tier 1 — item count to unlock",
      "min": 0, "max": 100, "step": 1, "default": 2
    },
    {
      "type": "text",
      "id": "tier_2_label",
      "label": "Tier 1 threshold label",
      "default": "2+ Items",
      "info": "Shown above the card (e.g. '2+ Items' or 'Shop $50+')"
    },
    {
      "type": "text",
      "id": "tier_2_reward",
      "label": "Tier 1 reward text",
      "default": "Free Shipping",
      "info": "Shown inside the card when unlocked"
    },
    {
      "type": "text",
      "id": "tier_2_gift_image",
      "label": "Tier 1 gift image URL",
      "info": "Optional product image for the reward card"
    },
    {
      "type": "text",
      "id": "tier_2_value_badge",
      "label": "Tier 1 value badge",
      "info": "e.g. '$15 VALUE' — leave blank to hide"
    },
    {
      "type": "range",
      "id": "discount_3_items",
      "label": "Tier 2 — item count to unlock",
      "min": 0, "max": 100, "step": 1, "default": 3
    },
    {
      "type": "text",
      "id": "tier_3_label",
      "label": "Tier 2 threshold label",
      "default": "3+ Items"
    },
    {
      "type": "text",
      "id": "tier_3_reward",
      "label": "Tier 2 reward text",
      "default": "Free Gift"
    },
    {
      "type": "text",
      "id": "tier_3_gift_image",
      "label": "Tier 2 gift image URL"
    },
    {
      "type": "text",
      "id": "tier_3_value_badge",
      "label": "Tier 2 value badge"
    },
    {
      "type": "range",
      "id": "discount_4_items",
      "label": "Tier 3 — item count to unlock",
      "min": 0, "max": 100, "step": 1, "default": 5
    },
    {
      "type": "text",
      "id": "tier_4_label",
      "label": "Tier 3 threshold label",
      "default": "5+ Items"
    },
    {
      "type": "text",
      "id": "tier_4_reward",
      "label": "Tier 3 reward text",
      "default": "Best Deal"
    },
    {
      "type": "text",
      "id": "tier_4_gift_image",
      "label": "Tier 3 gift image URL"
    },
    {
      "type": "text",
      "id": "tier_4_value_badge",
      "label": "Tier 3 value badge"
    },
    {
      "type": "range",
      "id": "discount_5_items",
      "label": "Tier 4 — item count to unlock (0 to disable)",
      "min": 0, "max": 100, "step": 1, "default": 0
    },
    {
      "type": "text",
      "id": "tier_5_label",
      "label": "Tier 4 threshold label",
      "default": "7+ Items"
    },
    {
      "type": "text",
      "id": "tier_5_reward",
      "label": "Tier 4 reward text",
      "default": "VIP Bundle"
    },
    {
      "type": "text",
      "id": "tier_5_gift_image",
      "label": "Tier 4 gift image URL"
    },
    {
      "type": "text",
      "id": "tier_5_value_badge",
      "label": "Tier 4 value badge"
    },
    {
      "type": "range",
      "id": "min_items",
      "label": "Minimum items",
      "min": 1, "max": 8, "step": 1, "default": 2
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum items",
      "min": 2, "max": 20, "step": 1, "default": 8
    },
    {
      "type": "header",
      "content": "Tab Content & Icons"
    },
    {
      "type": "richtext",
      "id": "size_guide",
      "label": "Size guide",
      "default": "<h3><strong>Twin</strong></h3><p>Includes: 1 Flat Sheet (66\" x 96\"), 1 Fitted Sheet (39\" x 75\"), 1 Pillowcase (20\" x 30\")</p><h3><strong>Queen</strong></h3><p>Includes: 1 Flat Sheet (90\" x 102\"), 1 Fitted Sheet (60\" x 80\"), 2 Pillowcases (20\" x 30\")</p><h3><strong>King</strong></h3><p>Includes: 1 Flat Sheet (108\" x 102\"), 1 Fitted Sheet (78\" x 80\"), 2 Pillowcases (20\" x 40\")</p>"
    },
    {
      "type": "richtext",
      "id": "shipping_info",
      "label": "Shipping information",
      "default": "<p>We offer free standard shipping on all orders over $50. Orders are processed within 1-2 business days and typically arrive within 3-5 business days.</p>"
    },
    {
      "type": "richtext",
      "id": "care_info",
      "label": "Care instructions",
      "default": "<p>Machine wash cold with like colors. Tumble dry low. Do not bleach. Iron on low heat if needed.</p>"
    },
    {
      "type": "image_picker",
      "id": "icon_1_image",
      "label": "Icon 1 image"
    },
    {
      "type": "text",
      "id": "icon_1_label",
      "label": "Icon 1 label",
      "default": "Best Seller"
    },
    {
      "type": "image_picker",
      "id": "icon_2_image",
      "label": "Icon 2 image"
    },
    {
      "type": "text",
      "id": "icon_2_label",
      "label": "Icon 2 label",
      "default": "Breathable"
    },
    {
      "type": "image_picker",
      "id": "icon_3_image",
      "label": "Icon 3 image"
    },
    {
      "type": "text",
      "id": "icon_3_label",
      "label": "Icon 3 label"
    },
    {
      "type": "image_picker",
      "id": "icon_4_image",
      "label": "Icon 4 image"
    },
    {
      "type": "text",
      "id": "icon_4_label",
      "label": "Icon 4 label"
    },
    {
      "type": "header",
      "content": "Button & Colors"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "checkbox",
      "id": "cart_redirect",
      "label": "Redirect to cart after adding",
      "default": false
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#182f5c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_variant_selector",
      "label": "Show variant selector (color/size)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show savings callout",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tier_progress",
      "label": "Show tier progress bar",
      "default": true
    }
  ]
}
{% endschema %}
