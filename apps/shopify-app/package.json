{
  "name": "@cgk-platform/shopify-app",
  "version": "0.0.0",
  "private": true,
  "description": "CGK Platform Shopify App — Bundle Builder, Delivery Customization, Session Stitching, Post-Purchase Survey",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "vercel-build": "prisma generate && remix vite:build",
    "postinstall": "prisma generate",
    "dev": "shopify app dev",
    "start": "remix-serve ./build/server/index.js",
    "setup": "prisma generate",
    "deploy": "shopify app deploy",
    "deploy:force": "shopify app deploy --force",
    "config:link": "shopify app config link",
    "config:push": "shopify app config push",
    "info": "shopify app info",
    "env:show": "shopify app env show",
    "generate:extension": "shopify app generate extension",
    "function:run": "shopify app function run",
    "function:typegen": "shopify app function typegen",
    "logs": "shopify app logs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist build .shopify",
    "prisma": "prisma",
    "shopify": "shopify",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@remix-run/dev": "^2.16.1",
    "@remix-run/fs-routes": "^2.16.1",
    "@remix-run/node": "^2.16.1",
    "@remix-run/react": "^2.16.1",
    "@remix-run/serve": "^2.16.1",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^12.0.0",
    "@shopify/shopify-app-remix": "^4.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "@vercel/remix": "^2.16.7",
    "isbot": "^5.1.0",
    "prisma": "^6.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "devDependencies": {
    "@remix-run/route-config": "^2.16.1",
    "@shopify/api-codegen-preset": "^1.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "typescript": "^5.9.0",
    "vite": "^6.2.2"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  }
}
