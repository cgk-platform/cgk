# openCLAW Command Center Environment Variables

# Gateway auth tokens (from each profile's .env GATEWAY_AUTH_TOKEN)
OPENCLAW_CGK_GATEWAY_TOKEN=
OPENCLAW_RAWDOG_GATEWAY_TOKEN=
OPENCLAW_VITA_GATEWAY_TOKEN=

# Gateway ports (defaults provided — only override if non-standard)
OPENCLAW_CGK_PORT=18789
OPENCLAW_RAWDOG_PORT=19001
OPENCLAW_VITA_PORT=19021

# Standard (shared with orchestrator)
DATABASE_URL=
JWT_SECRET=
SESSION_SECRET=
