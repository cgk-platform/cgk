# ============================================================================
# CGK PLATFORM - BRAND ENVIRONMENT VARIABLE TEMPLATE
# ============================================================================
#
# This file is a TEMPLATE for brands forking the CGK Platform.
# Copy this to each app's .env.local file and fill in YOUR values.
#
# IMPORTANT: This file should be used for:
#   apps/admin/.env.local
#   apps/storefront/.env.local
#   apps/creator-portal/.env.local
#   apps/contractor-portal/.env.local
#
# For production, add these to Vercel using:
#   cd apps/<app-name>
#   vercel env add VAR_NAME production --scope your-team
#   vercel env add VAR_NAME preview --scope your-team
#   vercel env add VAR_NAME development --scope your-team
#
# Then pull to local:
#   vercel env pull .env.local --scope your-team
#
# ============================================================================

