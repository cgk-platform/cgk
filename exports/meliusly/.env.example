# CGK Platform - Environment Variables
# Tenant: meliusly
# Generated: 2026-03-04T04:07:33.529Z

# Database
POSTGRES_URL=<neon-database-connection-string>
POSTGRES_PRISMA_URL=${POSTGRES_URL}?pgbouncer=true
POSTGRES_URL_NON_POOLING=${POSTGRES_URL}

# Redis Cache
UPSTASH_REDIS_REST_URL=<upstash-redis-rest-url>
UPSTASH_REDIS_REST_TOKEN=<upstash-redis-rest-token>

# Authentication Secrets
JWT_SECRET=<generate-32-byte-hex>
SESSION_SECRET=<generate-32-byte-hex>
CREATOR_JWT_SECRET=<generate-32-byte-hex>
CONTRACTOR_JWT_SECRET=<generate-32-byte-hex>

# Encryption Keys
ENCRYPTION_KEY=<generate-32-byte-hex>
INTEGRATION_ENCRYPTION_KEY=<generate-32-byte-hex>
SHOPIFY_TOKEN_ENCRYPTION_KEY=<generate-32-byte-hex>
DAM_TOKEN_ENCRYPTION_KEY=<generate-32-byte-hex>
TAX_TIN_ENCRYPTION_KEY=<generate-32-byte-hex>

# Platform
CGK_PLATFORM_API_KEY=<generate-base64-api-key>
TENANT_SLUG=meliusly

# Shopify Integration
SHOPIFY_STORE_DOMAIN=meliusly.myshopify.com
