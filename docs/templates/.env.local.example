# ============================================================================
# CGK PLATFORM - LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================================================
#
# Copy this file to each app's .env.local:
#   cp docs/templates/.env.local.example apps/admin/.env.local
#   cp docs/templates/.env.local.example apps/storefront/.env.local
#   etc.
#
# Then fill in the values below.
#
# ============================================================================

# ============================================================================
# DATABASE (REQUIRED)
# ============================================================================
# PostgreSQL connection string

# Option A: Docker (recommended for local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cgk

# Option B: Neon (free tier - production-like)
# DATABASE_URL=postgresql://user:pass@ep-cool-voice-123456.us-east-2.aws.neon.tech/neondb

# Postgres.js (alternative to DATABASE_URL)
# POSTGRES_URL=<same as DATABASE_URL>

# ============================================================================
# REDIS (OPTIONAL FOR LOCAL DEV)
# ============================================================================
# Redis connection for caching

# Option A: Docker
REDIS_URL=redis://localhost:6379

# Option B: Upstash (free tier)
# REDIS_URL=https://your-redis-12345.upstash.io
# KV_REST_API_URL=https://your-redis-12345.upstash.io
# KV_REST_API_TOKEN=your-token-here

# ============================================================================
# AUTHENTICATION SECRETS (REQUIRED)
# ============================================================================
# Generate with: ./scripts/generate-brand-secrets.sh local-dev

# JWT signing secret (64 chars)
JWT_SECRET=your-jwt-secret-here-min-32-chars-use-openssl-rand-hex-32

# Session encryption secret (64 chars)
SESSION_SECRET=your-session-secret-here-min-32-chars-use-openssl-rand-hex-32

# Data encryption key (64 chars)
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars-use-openssl-rand-hex-32

# Creator portal JWT secret (if using creator portal)
CREATOR_JWT_SECRET=your-creator-jwt-secret-here-min-32-chars

# Contractor portal JWT secret (if using contractor portal)
CONTRACTOR_JWT_SECRET=your-contractor-jwt-secret-here-min-32-chars

# ============================================================================
# TENANT CONFIGURATION (REQUIRED)
# ============================================================================
# Default tenant for local development

DEFAULT_TENANT_SLUG=local-dev

# ============================================================================
# APPLICATION URLS (LOCAL DEVELOPMENT)
# ============================================================================

APP_URL=http://localhost:3200
NEXT_PUBLIC_ADMIN_URL=http://localhost:3200
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3300
NEXT_PUBLIC_CREATOR_PORTAL_URL=http://localhost:3400
CONTRACTOR_PORTAL_URL=http://localhost:3500
NEXT_PUBLIC_SITE_NAME=CGK Platform

# ============================================================================
# SHOPIFY INTEGRATION (OPTIONAL)
# ============================================================================
# Leave blank for local dev without Shopify
# Fill in when testing Shopify features

# Shopify App credentials (from Partners dashboard)
# SHOPIFY_CLIENT_ID=your-client-id
# SHOPIFY_CLIENT_SECRET=your-client-secret

# Shopify store domain
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront Access Token (for headless storefront)
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token

# Shopify Admin API Access Token (from app installation)
# SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_your-token

# Shopify App API Key (for Remix app)
# SHOPIFY_API_KEY=your-api-key
# SHOPIFY_API_SECRET=your-api-secret
# SCOPES=read_products,write_products,read_orders,write_orders

# ============================================================================
# STRIPE PAYMENTS (OPTIONAL)
# ============================================================================
# Leave blank for local dev without payments
# Use test keys (sk_test_...) for development

# Stripe secret key
# STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe publishable key (for frontend)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Connect (for creator/contractor payments)
# STRIPE_CONNECT_CLIENT_ID=ca_your-client-id

# ============================================================================
# WISE PAYMENTS (OPTIONAL)
# ============================================================================
# International payments for contractors

# WISE_API_KEY=your-wise-api-key
# WISE_PROFILE_ID=your-profile-id

# ============================================================================
# EMAIL (OPTIONAL)
# ============================================================================
# Resend for transactional emails

# RESEND_API_KEY=re_your-api-key

# ============================================================================
# BACKGROUND JOBS (OPTIONAL)
# ============================================================================

# Trigger.dev (background jobs)
# TRIGGER_SECRET_KEY=tr_dev_your-secret

# Inngest (alternative to Trigger.dev)
# INNGEST_EVENT_KEY=your-event-key
# INNGEST_SIGNING_KEY=your-signing-key

# ============================================================================
# STORAGE (OPTIONAL)
# ============================================================================

# Vercel Blob (file uploads)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token

# ============================================================================
# AI FEATURES (OPTIONAL)
# ============================================================================

# OpenAI API key
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic API key (for Claude features)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ============================================================================
# ANALYTICS (OPTIONAL)
# ============================================================================

# Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
# GSC_CLIENT_ID=your-client-id
# GSC_CLIENT_SECRET=your-client-secret

# ============================================================================
# MONITORING & LOGGING (OPTIONAL)
# ============================================================================

# Sentry (error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Vercel Analytics
# VERCEL_ANALYTICS_ID=your-analytics-id

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Skip environment validation (for CI builds)
# SKIP_ENV_VALIDATION=1

# Node environment
NODE_ENV=development

# Enable debug logging
# DEBUG=*

# ============================================================================
# ENCRYPTION KEYS FOR INTEGRATIONS (OPTIONAL)
# ============================================================================
# Used to encrypt sensitive data in database

# INTEGRATION_ENCRYPTION_KEY=your-integration-encryption-key-64-chars
# SHOPIFY_TOKEN_ENCRYPTION_KEY=your-shopify-token-encryption-key-64-chars
# DAM_TOKEN_ENCRYPTION_KEY=your-dam-token-encryption-key-64-chars
# TAX_TIN_ENCRYPTION_KEY=your-tax-tin-encryption-key-64-chars
# TAX_ENCRYPTION_KEY=your-tax-encryption-key-64-chars
# SLACK_TOKEN_ENCRYPTION_KEY=your-slack-token-encryption-key-64-chars
# GSC_ENCRYPTION_KEY=your-gsc-encryption-key-64-chars
# GOOGLE_ADS_ENCRYPTION_KEY=your-google-ads-encryption-key-64-chars
# META_ENCRYPTION_KEY=your-meta-encryption-key-64-chars
# TIKTOK_ENCRYPTION_KEY=your-tiktok-encryption-key-64-chars

# ============================================================================
# PLATFORM API KEYS (OPTIONAL)
# ============================================================================
# For inter-app communication

# CGK_PLATFORM_API_KEY=your-platform-api-key-base64
# INTERNAL_API_KEY=your-internal-api-key-base64
# PLATFORM_API_KEY=your-platform-api-key-base64

# ============================================================================
# NOTES
# ============================================================================
#
# REQUIRED for basic operation:
#   - DATABASE_URL
#   - JWT_SECRET
#   - SESSION_SECRET
#   - ENCRYPTION_KEY
#   - DEFAULT_TENANT_SLUG
#
# OPTIONAL (platform works without these):
#   - REDIS_URL (caching - improves performance)
#   - SHOPIFY_* (only needed for Shopify features)
#   - STRIPE_* (only needed for payments)
#   - Everything else (feature-specific)
#
# SECURITY:
#   - NEVER commit .env.local to git (already in .gitignore)
#   - Use ./scripts/generate-brand-secrets.sh to generate secure secrets
#   - Store production secrets in 1Password/Vault, not in files
#
# HELP:
#   - Full guide: docs/getting-started/LOCAL-DEVELOPMENT-SETUP.md
#   - Credential acquisition: docs/getting-started/CREDENTIAL-ACQUISITION.md
#   - Troubleshooting: docs/TROUBLESHOOTING.md
#
# ============================================================================
